<h2><%= t.register_title %></h2>
<form id="registerForm" class="mt-4">
    <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0"><%= t.register %></h3>
                </div>
                <div class="card-body">
                    <form action="/auth/register" method="POST">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" name="email" id="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" name="password" id="password" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="role" class="form-label">Role</label>
                            <select name="role" id="role" class="form-select">
                                <option value="seeker">Job Seeker</option>
                                <option value="employer">Employer</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success w-100"><%= t.register %></button>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <a href="/auth/login" class="text-decoration-none"><%= t.login %></a>
                </div>
            </div>
        </div>
    </div>
</div>
    <button type="submit" class="btn btn-success w-100">Kayıt Ol</button>
</form>

<script type="module">
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const role = document.getElementById('role').value;

        try {
            // 1. Firebase'de kullanıcı oluştur
            const userCredential = await window.createUser(window.firebaseAuth, email, password);
            const user = userCredential.user;

            // 2. Kendi backendimize UID ve Rol gönder
            const response = await fetch('/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, uid: user.uid, role })
            });

            const result = await response.json();
            if (result.status === 'success') {
                window.location.href = result.redirect; // Doğrulama sayfasına git
            }
        } catch (error) {
            alert("Error: " + error.message);
        }
    });
</script>