<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register - Job Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card shadow p-4" style="max-width: 400px; width: 100%;">
        <h3 class="text-center text-success mb-4">Create Account</h3>
        
        <div class="mb-3">
            <label>Email Address</label>
            <input type="email" id="email" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Password</label>
            <input type="password" id="password" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>I am a:</label>
            <select id="role" class="form-select">
                <option value="job_seeker">Job Seeker (Looking for a job)</option>
                <option value="employer">Employer (Hiring)</option>
            </select>
        </div>

        <button id="registerBtn" class="btn btn-success w-100">Register</button>
        <p class="text-center mt-3">Already have an account? <a href="/auth/login">Login</a></p>
        <div id="errorMsg" class="alert alert-danger mt-2 d-none"></div>
    </div>

    <script type="module">
        import { auth, createUserWithEmailAndPassword } from '/js/firebase-config.js';

        const registerBtn = document.getElementById('registerBtn');
        const errorMsg = document.getElementById('errorMsg');

        registerBtn.addEventListener('click', async () => {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const role = document.getElementById('role').value;

            try {
                // 1. ایجاد کاربر در Firebase
                const userCredential = await createUserWithEmailAndPassword(auth, email, password);
                const user = userCredential.user;

                // 2. ارسال اطلاعات به Backend خودمان (MySQL)
                const response = await fetch('/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        email: user.email, 
                        firebaseUid: user.uid,
                        role: role
                    })
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = '/';
                } else {
                    throw new Error(data.message);
                }

            } catch (error) {
                errorMsg.textContent = error.message;
                errorMsg.classList.remove('d-none');
            }
        });
    </script>
</body>
</html>