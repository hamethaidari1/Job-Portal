<div class="card p-4 mx-auto" style="max-width: 400px;">
    <h3 class="text-center text-success">E-posta Doğrulama</h3>
    <p class="text-muted text-center">Lütfen e-postanıza gönderilen 6 haneli kodu giriniz.</p>
    <p class="text-danger text-center small">(Demo: Kodu VS Code Terminalinden alın)</p>
    
    <input type="text" id="code" class="form-control text-center fs-3 letter-spacing-2" maxlength="6" placeholder="000000">
    <button onclick="verify()" class="btn btn-success w-100 mt-3">Doğrula</button>
</div>

<script>
    async function verify() {
        const code = document.getElementById('code').value;
        const res = await fetch('/auth/verify-code', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code })
        });
        const data = await res.json();
        if(data.status === 'success') location.href = '/';
        else alert(data.message);
    }
</script>