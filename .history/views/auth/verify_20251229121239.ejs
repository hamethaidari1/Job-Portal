<%- include('../includes/header') %>

<div class="container py-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    <h4 class="fw-bold mb-2">Hesap Doğrulama</h4>
                    <p class="text-muted mb-2">Devam etmek için hesabınızı doğrulayın.</p>
                    <p class="text-muted mb-4">
                        <span class="fw-bold"><%= email %></span> adresine 6 haneli doğrulama kodu gönderilecektir.
                    </p>

                    <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
                        <div class="alert alert-danger">
                            <%= errorMessage %>
                        </div>
                    <% } %>

                    <% if (typeof successMessage !== "undefined" && successMessage) { %>
                        <div class="alert alert-success">
                            <%= successMessage %>
                        </div>
                    <% } %>

                    <!-- KOD GÖNDER -->
                    <% if (typeof sent === "undefined" || !sent) { %>
                        <form action="/auth/verify/send" method="POST" class="mb-3">
                            <button type="submit" class="btn btn-success w-100 fw-bold">
                                Doğrulama Kodunu Gönder
                            </button>
                        </form>
                    <% } %>

                    <!-- KOD DOĞRULA -->
                    <% if (typeof sent !== "undefined" && sent) { %>
                        <form action="/auth/verify/confirm" method="POST">
                            <div class="mb-3">
                                <input
                                    type="text"
                                    name="code"
                                    id="verificationCode"
                                    class="form-control text-center"
                                    placeholder="000000"
                                    maxlength="6"
                                    required
                                >
                            </div>

                            <button
                                type="submit"
                                id="verifyBtn"
                                class="btn btn-danger w-100 fw-bold"
                                disabled
                            >
                                Kodu Doğrula
                            </button>
                        </form>

                        <script>
                            const codeInput = document.getElementById('verificationCode');
                            const verifyBtn = document.getElementById('verifyBtn');
                            const verifyForm = document.querySelector('form[action="/auth/verify/confirm"]');

                            codeInput.addEventListener('input', function () {
                                const code = this.value;

                                if (code.length === 6) {
                                    verifyBtn.classList.remove('btn-danger');
                                    verifyBtn.classList.add('btn-success');
                                    verifyBtn.disabled = false;

                                    // Otomatik form gönderimi
                                    verifyForm.submit();
                                } else {
                                    verifyBtn.classList.remove('btn-success');
                                    verifyBtn.classList.add('btn-danger');
                                    verifyBtn.disabled = true;
                                }
                            });

                            // Otomatik fokus
                            codeInput.focus();
                        </script>
                    <% } %>

                    <a href="/" class="btn btn-link mt-3">Ana sayfaya dön</a>

                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../includes/footer') %>
