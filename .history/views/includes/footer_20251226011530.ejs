<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <style>
        footer {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            border-top: 1px solid #e4e7e4;
            color: #74767e;
        }
        footer h5 {
            color: #404145;
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
        }
        footer ul li {
            margin-bottom: 12px;
        }
        footer ul li a {
            color: #74767e;
            font-size: 16px;
            transition: color 0.2s;
        }
        footer ul li a:hover {
            color: #222325;
            text-decoration: underline !important;
        }
        .footer-bottom {
            padding: 24px 0;
            border-top: 1px solid #e4e5e7;
        }
        .footer-logo {
            font-size: 24px;
            font-weight: 900;
            color: #74767e;
            letter-spacing: -1px;
        }
        .social-icons a {
            font-size: 20px;
            color: #74767e;
            margin-left: 20px;
            transition: 0.3s;
        }
        .social-icons a:hover {
            color: #404145;
            background-color: #659149;
            border-radius: 50%;
        }
    </style>

    <footer class="bg-white mt-auto pt-5">
        <div class="container">
            <div class="row pb-4">
                <div class="col-6 col-md-3 col-lg-2 mb-4">
                    <h5><%= t('footer.links_title') %></h5>
                    <ul class="list-unstyled">
                        <li><a href="/jobs" class="text-decoration-none"><%= t('footer.about') %></a></li>
                        <li><a href="/help" class="text-decoration-none"><%= t('footer.contact') %></a></li>
                        <li><a href="/privacy" class="text-decoration-none">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-3 col-lg-2 mb-4">
                    <h5><%= t('footer.support_title') %></h5>
                    <ul class="list-unstyled">
                        <li><a href="/help" class="text-decoration-none"><%= t('footer.help') %></a></li>
                        <li><a href="/trust" class="text-decoration-none"><%= t('footer.trust') %></a></li>
                        <li><a href="/settings" class="text-decoration-none">Settings</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 col-lg-4 ms-auto mb-4">
                    <h5 class="text-uppercase">İŞBUL.ONLINE</h5>
                    <p style="line-height: 1.6;">
                        <%= t('footer.brand_desc') %>
                    </p>
                </div>
            </div>

            <div class="footer-bottom d-flex flex-wrap justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <span class="footer-logo me-3">İŞBUL.ONLINE</span>
                    <small class="text-muted">© <%= new Date().getFullYear() %> İşbul Online Ltd.</small>
                </div>
                
                <div class="social-icons d-flex align-items-center mt-3 mt-md-0">
                    <a href="#"><i class="bi bi-tiktok"></i></a>
                    <a href="#"><i class="bi bi-instagram"></i></a>
                    <a href="#"><i class="bi bi-linkedin"></i></a>
                    <a href="#"><i class="bi bi-facebook"></i></a>
                    <a href="#"><i class="bi bi-twitter-x"></i></a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>