<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Available Jobs</h2>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body bg-white rounded">
        <form action="/" method="GET" class="row g-2">
            <div class="col-md-10">
                <input type="text" name="search" class="form-control" placeholder="Search jobs..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <% if (jobs.length > 0) { %>
        <% jobs.forEach(job => { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 job-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <h5 class="card-title text-success fw-bold"><%= job.title %></h5>
                            <span class="badge bg-light text-dark border"><%= job.jobType %></span>
                        </div>
                        <h6 class="text-muted mb-3"><i class="bi bi-building"></i> <%= job.companyName %></h6>
                        <p class="text-secondary small mb-3">
                            <i class="bi bi-geo-alt-fill text-danger"></i> <%= job.location %>
                        </p>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">$<%= job.salary %></span>
                            <a href="/jobs/<%= job.id %>" class="btn btn-sm btn-outline-success">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col-12 text-center py-5">
            <div class="text-muted opacity-50">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">No jobs found.</p>
            </div>
        </div>
    <% } %>
</div>