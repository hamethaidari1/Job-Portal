<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">JobPortal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto align-items-center">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <span class="text-white me-3"><%= user.email %></span>
                        <a href="/jobs/create" class="btn btn-light btn-sm me-2 text-success fw-bold">Post Job</a>
                        <a href="/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
                    <% } else { %>
                        <a href="/auth/login" class="nav-link text-white me-2">Login</a>
                        <a href="/auth/register" class="btn btn-outline-light btn-sm">Register</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark">Available Jobs</h2>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body bg-white rounded">
                <form action="/" method="GET" class="row g-2">
                    <div class="col-md-10">
                        <input type="text" name="search" class="form-control" placeholder="Search jobs...">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-success w-100">Search</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row">
            <% if (jobs.length > 0) { %>
                <% jobs.forEach(job => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <h5 class="card-title text-success fw-bold"><%= job.title %></h5>
                                    <span class="badge bg-light text-dark border"><%= job.jobType %></span>
                                </div>
                                <h6 class="text-muted mb-3"><%= job.companyName %></h6>
                                <p class="text-secondary small"><%= job.location %></p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="fw-bold">$<%= job.salary %></span>
                                    <a href="/jobs/<%= job.id %>" class="btn btn-sm btn-outline-success">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No jobs found.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>