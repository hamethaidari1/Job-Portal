<%- include('includes/header') %>

<header class="hero-section py-5 mb-5" style="background-color: #0a4226; color: white;">
    <div class="container py-5 text-center">
        <h1 class="display-4 fw-bold mb-4">Connect with the best <span style="color: #1dbf73;">opportunities</span></h1>
        <p class="lead mb-5 opacity-75">Find the perfect job service for your business or career growth.</p>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <form action="/" method="GET" class="input-group input-group-lg shadow-lg" style="border-radius: 8px; overflow: hidden;">
                    <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-0 px-3" placeholder="What service are you looking for today?" value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
                    <button type="submit" class="btn btn-success px-5 fw-bold" style="background-color: #1dbf73; border: none;">Search</button>
                </form>
            </div>
        </div>
    </div>
</header>

<div class="container mb-5">
    <div class="mb-5">
        <h4 class="fw-bold mb-4 text-dark">Popular Services</h4>
        <div class="row g-3">
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-code-slash fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Development</span>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-palette fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Design</span>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-megaphone fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Marketing</span>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-translate fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Writing</span>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-camera-reels fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Video</span>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="category-card text-center p-3 border rounded shadow-sm bg-white h-100">
                    <i class="bi bi-database-check fs-2 text-success mb-2 d-block"></i>
                    <span class="small fw-bold">Data</span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold text-dark m-0">Recent Job Opportunities</h3>
        <a href="/" class="text-success text-decoration-none fw-bold small">Explore more <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row g-4">
        <% if (jobs && jobs.length > 0) { %>
            <% jobs.forEach(job => { %>
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden job-card-hover">
                        <div class="position-relative">
                            <img src="<%= job.companyLogo ? '/uploads/' + job.companyLogo : 'https://placehold.co/400x250/f8f9fa/1dbf73?text=Job+Service' %>" class="card-img-top" style="height: 180px; object-fit: cover;">
                        </div>
                        
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                    <i class="bi bi-person-circle text-muted small"></i>
                                </div>
                                <span class="fw-bold small text-dark"><%= job.companyName %></span>
                                <span class="ms-auto badge bg-light text-muted border-0 fw-normal small">Level 2</span>
                            </div>
                            <a href="/jobs/<%= job.id %>" class="text-decoration-none">
                                <h6 class="card-title text-dark mb-3 line-clamp-2" style="min-height: 48px; line-height: 1.4;"><%= job.title %></h6>
                            </a>
                            <div class="text-warning small mb-3">
                                <i class="bi bi-star-fill"></i> <i class="bi bi-star-fill"></i> <i class="bi bi-star-fill"></i> <i class="bi bi-star-fill"></i> <i class="bi bi-star-fill"></i>
                                <span class="text-muted ms-1">(1k+)</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center p-3">
                            <i class="bi bi-heart-fill text-muted"></i>
                            <div class="text-end">
                                <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase;">Starting at</small>
                                <span class="fw-bold text-dark fs-5">$<%= job.salary %></span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5 bg-white rounded shadow-sm">
                <p class="text-muted">No services found for your search.</p>
            </div>
        <% } %>
    </div>
</div>

<style>
    .job-card-hover:hover {
    transform: translateY(-8px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
}
    .job-card-hover { transition: transform 0.3s ease; cursor: pointer; }
    .job-card-hover:hover { transform: translateY(-8px); }
    .category-card { transition: all 0.2s ease; cursor: pointer; }
    .category-card:hover { border-color: #1dbf73 !important; color: #1dbf73; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<%- include('includes/footer') %>