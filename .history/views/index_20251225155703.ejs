<%- include('includes/header') %>

<style>
    :root {
        --navbar-height: 80px;
        --fiverr-green: #1dbf73;
        --dark-green: #0a4226;
    }

    body { margin: 0; padding: 0; background-color: #f7f7f7; }

    /* ایجاد فاصله برای اینکه محتوا زیر نوار ناوبری فیکس نماند */
    .main-wrapper {
        padding-top: var(--navbar-height);
    }

    .hero-section {
        background-color: var(--dark-green);
        padding: 80px 0 100px 0;
        position: relative;
    }

    .job-card-hover { 
        transition: all 0.3s ease; 
        border: 1px solid #efeff0 !important;
        border-radius: 8px;
    }

    .job-card-hover:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 8px 15px rgba(0,0,0,0.08) !important;
    }
    
    .category-card { 
        transition: all 0.2s ease; 
        border: 1px solid #e4e5e7 !important;
        background-color: white;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .category-card:hover { 
        border-color: var(--fiverr-green) !important; 
        color: var(--fiverr-green); 
    }

    .line-clamp-2 { 
        display: -webkit-box; 
        -webkit-line-clamp: 2; 
        -webkit-box-orient: vertical; 
        overflow: hidden; 
    }

    .search-bar-wrap {
        background: white;
        border-radius: 4px;
        padding: 4px;
    }
</style>

<div class="main-wrapper">
    <main>
        <header class="hero-section">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-8 offset-lg-2 text-center">
                        <h1 class="display-4 fw-bold text-white mb-3">
                            Find the perfect <span style="color: var(--fiverr-green);">freelance</span> services
                        </h1>
                        <p class="fs-5 text-white opacity-75 mb-5">
                            Work with talented people at the most affordable price
                        </p>
                        
                        <div class="search-bar-wrap shadow-lg">
                            <form action="/" method="GET" class="d-flex">
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                                    <input type="text" name="search" class="form-control border-0 py-3 shadow-none" placeholder='Try "logo design"'>
                                    <button type="submit" class="btn btn-success px-5 fw-bold" style="background-color: var(--fiverr-green); border: none;">Search</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="container py-5">
            <div class="mb-5">
                <h4 class="fw-bold mb-4 text-dark">Popular Services</h4>
                <div class="row g-3 text-center">
                    <% 
                    const categories = [
                        { name: 'Development', icon: 'bi-code-slash' },
                        { name: 'Design', icon: 'bi-palette' },
                        { name: 'Marketing', icon: 'bi-megaphone' },
                        { name: 'Writing', icon: 'bi-translate' },
                        { name: 'Video', icon: 'bi-camera-reels' },
                        { name: 'Data', icon: 'bi-database-check' }
                    ];
                    categories.forEach(cat => { 
                    %>
                    <div class="col-6 col-md-2">
                        <a href="/?search=<%= cat.name %>" class="category-card p-3 rounded shadow-sm h-100">
                            <i class="bi <%= cat.icon %> fs-2 text-success mb-2 d-block"></i>
                            <span class="small fw-bold"><%= cat.name %></span>
                        </a>
                    </div>
                    <% }) %>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-end mb-4">
                <h3 class="fw-bold text-dark m-0">Recent Gigs</h3>
                <a href="/" class="text-success text-decoration-none fw-bold small">Explore more <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="row g-4">
                <% if (typeof jobs !== 'undefined' && jobs.length > 0) { %>
                    <% jobs.forEach(job => { %>
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden job-card-hover bg-white">
                                <a href="/jobs/<%= job.id %>">
                                    <img src="<%= job.companyLogo ? '/uploads/' + job.companyLogo : 'https://placehold.co/400x250/f8f9fa/cccccc?text=Job+Service' %>" 
                                         class="card-img-top" 
                                         style="height: 170px; object-fit: cover;" 
                                         alt="<%= job.title %>">
                                </a>
                                
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="user-avatar-mini me-2">
                                            <i class="bi bi-person-circle text-muted fs-5"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold small text-dark d-block"><%= job.companyName %></span>
                                            <span class="text-muted" style="font-size: 11px;">Top Rated Seller</span>
                                        </div>
                                    </div>
                                    
                                    <a href="/jobs/<%= job.id %>" class="text-decoration-none">
                                        <h6 class="card-title text-dark mb-2 line-clamp-2 fw-normal" style="height: 42px;"><%= job.title %></h6>
                                    </a>

                                    <div class="text-warning small">
                                        <i class="bi bi-star-fill"></i>
                                        <span class="fw-bold ms-1">5.0</span>
                                        <span class="text-muted ms-1">(1k+)</span>
                                    </div>
                                </div>
                                
                                <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center p-3">
                                    <i class="bi bi-heart-fill text-muted" style="cursor: pointer;"></i>
                                    <div class="text-end">
                                        <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase;">Starting at</small>
                                        <span class="fw-bold text-dark fs-5">$<%= job.salary %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5 bg-white rounded shadow-sm border">
                        <i class="bi bi-search fs-1 text-muted d-block mb-3"></i>
                        <p class="text-muted">No services found. Try a different search term.</p>
                        <a href="/" class="btn btn-sm btn-success">Clear Filters</a>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div> <%- include('includes/footer') %>