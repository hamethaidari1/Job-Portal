<style>
  :root {
    --fiverr-green: #1dbf73;
    --dark-green: #0a4226;
  }

  .hero-section {
    background-color: var(--dark-green);
    padding: 90px 0 110px;
  }
</style>

<header class="hero-section text-center">
  <div class="container">
    <h1 class="display-4 fw-bold text-white mb-3">
      Find the perfect <span style="color: var(--fiverr-green);">freelance</span> services
    </h1>
    <p class="fs-5 text-white opacity-75 mb-5">
      Work with talented people at the most affordable price
    </p>

    <form action="/" method="GET" class="d-flex justify-content-center">
      <div class="input-group w-75 shadow-lg">
        <span class="input-group-text bg-white border-0">
          <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="search" class="form-control border-0 py-3 shadow-none"
               placeholder='Try "logo design"'>
        <button class="btn btn-success px-5 fw-bold"
                style="background-color: var(--fiverr-green); border: none;">
          Search
        </button>
      </div>
    </form>
  </div>
</header>

<div class="container py-5">
  <h3 class="fw-bold mb-4">Recent Gigs</h3>

  <div class="row g-4">
    <% if (jobs && jobs.length) { %>
      <% jobs.forEach(job => { %>
        <div class="col-md-3">
          <div class="card h-100 shadow-sm">
            <img src="<%= job.companyLogo ? '/uploads/' + job.companyLogo : 'https://placehold.co/400x250' %>"
                 class="card-img-top" style="height:170px; object-fit:cover;">
            <div class="card-body">
              <h6 class="fw-bold"><%= job.title %></h6>
              <span class="text-muted small">$<%= job.salary %></span>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted text-center">No jobs found</p>
    <% } %>
  </div>
</div>
    <%- include('partials/footer') %>