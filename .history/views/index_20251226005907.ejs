<%- include('includes/header') %>

<style>
    :root {
        --navbar-height: 80px;
        --fiverr-green: #1dbf73;
        --dark-green: #0a4226;
        --bg-light: #f7f7f7;
        --light-green-bg: #eefdf3;
    }

    body { 
        background-color: white !important;
        font-family: 'Macan', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .main-wrapper {
        /* Margin handled by body padding in header.ejs */
    }

    /* Hero Section */
    .hero-section {
        background-color: var(--dark-green);
        padding: 80px 0;
        color: white;
    }
    .hero-title {
        font-weight: 700;
        font-size: 3rem;
        color: white;
        margin-bottom: 20px;
    }

    /* Mobile Responsive Fixes */
    @media (max-width: 768px) {
        .hero-title {
            font-size: 2rem;
            line-height: 1.2;
        }
        .hero-subtitle {
            font-size: 1rem;
            margin-bottom: 20px;
        }
        .hero-section {
            padding: 40px 0;
        }
        .search-bar-container {
            max-width: 100%;
        }
        .popular-tags {
            display: none; /* Hide tags on very small screens to save space if needed, or keep them */
        }
    }
    .hero-subtitle {
        font-size: 1.2rem;
        color: white;
        margin-bottom: 30px;
    }
    .search-bar-container {
        max-width: 600px;
        position: relative;
        margin-bottom: 20px;
    }
    .search-input {
        width: 100%;
        padding: 12px 20px;
        padding-right: 50px;
        border-radius: 4px;
        border: none;
        font-size: 1rem;
    }
    .search-btn {
        position: absolute;
        right: 5px;
        top: 5px;
        background-color: var(--fiverr-green);
        color: white;
        border: none;
        border-radius: 4px;
        padding: 7px 15px;
        font-weight: bold;
    }
    .popular-tags {
        font-size: 0.9rem;
        color: white;
    }
    .popular-tag-item {
        color: white;
        border: 1px solid white;
        border-radius: 20px;
        padding: 2px 10px;
        margin-left: 5px;
        text-decoration: none;
        font-size: 0.8rem;
        display: inline-block;
        margin-bottom: 5px;
        transition: all 0.3s;
    }
    .popular-tag-item:hover {
        background-color: white;
        color: var(--dark-green);
    }

    /* Comparison Section */
    .comparison-section {
        padding: 60px 0;
        background-color: white;
    }
    .comparison-card {
        border: 1px solid #e4e5e7;
        border-radius: 8px;
        padding: 30px;
        height: 100%;
    }
    .fiverr-card {
        background-color: var(--light-green-bg);
        border: 1px solid var(--fiverr-green);
    }
    .check-icon {
        color: var(--fiverr-green);
        margin-right: 10px;
    }
    .feature-title {
        font-weight: 700;
        margin-top: 20px;
        margin-bottom: 10px;
        font-size: 0.9rem;
    }
    .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .feature-list li {
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: #62646a;
        display: flex;
        align-items: start;
    }
    .feature-list li i {
        min-width: 20px;
    }

    /* Guides Section */
    .guides-section {
        padding: 60px 0;
    }
    .guide-card {
        border: none;
        transition: transform 0.3s;
    }
    .guide-card:hover {
        transform: translateY(-5px);
    }
    .guide-img {
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 15px;
    }
    .guide-img img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    /* Skills Section */
    .skills-section {
        padding: 60px 0;
    }
    .skill-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        height: 200px;
        cursor: pointer;
        transition: opacity 0.3s;
    }
    .skill-card:hover {
        opacity: 0.9;
    }
    .skill-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .skill-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
        display: flex;
        align-items: flex-end;
        padding: 20px;
    }
    .skill-title {
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
    }

    /* How it works */
    .how-it-works {
        padding: 60px 0;
        text-align: center;
    }

    /* CTA */
    .cta-section {
        padding: 80px 0;
        text-align: center;
    }
    .btn-fiverr {
        background-color: var(--fiverr-green);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 4px;
        font-weight: 700;
        transition: background-color 0.3s;
    }
    .btn-fiverr:hover {
        background-color: var(--dark-green);
        color: white;
    }

    /* Existing Job Cards */
    .job-card-hover { 
        transition: all 0.3s ease; 
        border: 1px solid #efeff0 !important;
        background: white;
    }
    .job-card-hover:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 12px 20px rgba(0,0,0,0.1) !important;
    }
</style>

<div class="main-wrapper">
    <!-- Hero -->
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title"><%- t('home.hero_title') %></h1>
            
            <div class="search-bar-container">
                <form action="/jobs" method="GET">
                    <input type="text" name="search" class="search-input" placeholder="<%= t('home.search_placeholder') %>">
                    <button type="submit" class="search-btn"><%= t('common.search') %></button>
                </form>
            </div>

            <div class="popular-tags d-flex flex-wrap align-items-center">
                <span class="me-2"><%= t('home.popular') %></span>
                <a href="/jobs?search=Website Design" class="popular-tag-item"><%= t('home.tags.website_design') %></a>
                <a href="/jobs?search=WordPress" class="popular-tag-item"><%= t('home.tags.wordpress') %></a>
                <a href="/jobs?search=Logo Design" class="popular-tag-item"><%= t('home.tags.logo_design') %></a>
                <a href="/jobs?search=Video Editing" class="popular-tag-item"><%= t('home.tags.video_editing') %></a>
            </div>
        </div>
    </section>

    <!-- Platform Comparison -->
<section class="comparison-section">
    <div class="container">
        <div class="row g-4">

            <!-- Geleneksel Yöntemler -->
            <div class="col-md-6">
                <div class="comparison-card">
                    <h3 class="fw-bold mb-4">Geleneksel İş Bulma Yöntemleri</h3>

                    <div class="feature-group">
                        <div class="feature-title">İş İlanlarına Erişim</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-dash text-muted"></i> Şehir veya bölge ile sınırlı</li>
                            <li><i class="bi bi-dash text-muted"></i> Fiziksel başvuru gerektirir</li>
                        </ul>
                    </div>

                    <div class="feature-group">
                        <div class="feature-title">Hız ve Kolaylık</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-dash text-muted"></i> Zaman alan süreçler</li>
                            <li><i class="bi bi-dash text-muted"></i> Mesai saatlerine bağlı</li>
                        </ul>
                    </div>

                    <div class="feature-group">
                        <div class="feature-title">Bilgi Şeffaflığı</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-dash text-muted"></i> Şirket bilgileri sınırlı</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Online Platform -->
            <div class="col-md-6">
                <div class="comparison-card fiverr-card">
                    <h3 class="fw-bold mb-4">Online İş Bulma Platformu</h3>

                    <div class="feature-group">
                        <div class="feature-title">İş İlanlarına Erişim</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-check-circle-fill check-icon"></i> Ülke genelinde erişim</li>
                            <li><i class="bi bi-check-circle-fill check-icon"></i> Geniş iş fırsatları</li>
                        </ul>
                    </div>

                    <div class="feature-group">
                        <div class="feature-title">Hız ve Kolaylık</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-check-circle-fill check-icon"></i> Kolay kayıt ve kullanım</li>
                            <li><i class="bi bi-check-circle-fill check-icon"></i> Dakikalar içinde başvuru</li>
                        </ul>
                    </div>

                    <div class="feature-group">
                        <div class="feature-title">Bilgi Şeffaflığı</div>
                        <ul class="feature-list">
                            <li><i class="bi bi-check-circle-fill check-icon"></i> Detaylı ilan ve şirket bilgileri</li>
                            <li><i class="bi bi-check-circle-fill check-icon"></i> İlanları karşılaştırma imkânı</li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

   <section class="py-5" style="background-color: #f7f7f7;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0" style="color: #404145;"><%= t('home.recent_gigs.title') %></h3>
            <a href="/jobs" class="text-success text-decoration-none fw-bold">
                <%= t('home.recent_gigs.explore') %> <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="row g-4">
            <% if (locals.jobs && jobs.length > 0) { %>
                <% jobs.forEach(job => { %>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 job-card-hover border-0 shadow-sm overflow-hidden" style="border-radius: 8px;">
                            <div class="position-relative">
                                <a href="/jobs/<%= job.id %>">
                                    <% const imageUrl = job.companyLogo ? ('/uploads/' + job.companyLogo) : 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop'; %>
                                    <img 
                                        src="<%= imageUrl %>" 
                                        class="card-img-top" 
                                        style="height: 170px; object-fit: cover;" 
                                        alt="<%= job.title %>">
                                </a>
                            </div>
                            
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 26px; height: 26px; font-size: 12px; font-weight: bold;">
                                        <%= job.companyName ? job.companyName.charAt(0).toUpperCase() : 'U' %>
                                    </div>
                                    <span class="fw-bold small text-dark"><%= job.companyName %></span>
                                </div>
                                
                                <a href="/jobs/<%= job.id %>" class="text-decoration-none text-dark">
                                    <h6 class="card-title mb-2 line-clamp-2 fw-normal" style="min-height: 44px; line-height: 1.4; color: #404145;">
                                        <%= job.title %>
                                    </h6>
                                </a>

                                <div class="text-warning small d-flex align-items-center mb-3">
                                    <i class="bi bi-star-fill"></i>
                                    <span class="fw-bold ms-1 text-dark">5.0</span>
                                    <span class="text-muted ms-1">(1k+)</span>
                                </div>

                                <a href="/jobs/<%= job.id %>" class="btn btn-outline-success w-100 border-2 fw-bold btn-sm py-2" style="border-radius: 5px; transition: 0.3s;">
                                    View Details
                                </a>
                            </div>
                            
                            <div class="card-footer bg-white border-top d-flex justify-content-between align-items-center p-3">
                                <i class="bi bi-heart-fill text-muted" style="cursor: pointer;"></i>
                                <div class="text-end">
                                    <small class="text-muted d-block" style="font-size: 10px; font-weight: 700;">STARTING AT</small>
                                    <span class="fw-bold fs-5" style="color: #404145;">$<%= job.salary %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="bi bi-emoji-frown fs-1 text-muted"></i>
                    <p class="text-muted mt-2"><%= t('home.recent_gigs.no_services') %></p>
                </div>
            <% } %>
        </div>
    </div>
    <style>
        
    </style>
</section>


    <!-- Guides -->
    <section class="guides-section bg-light">
    <div class="container">
        <h3 class="fw-bold mb-4"><%= t('home.guides.title') %></h3>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="guide-card">
                    <div class="guide-img">
                        <img src="/img/vstovs.jpeg" alt="Fiverr vs kariyer.net">
                    </div>
                    <h5 class="fw-bold"><%= t('home.guides.guide1_title') %></h5>
                    <p class="text-muted small"><%= t('home.guides.guide1_desc') %></p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="guide-card">
                    <div class="guide-img">
                        <img src="/img/on.jpeg" alt="Online Business">
                    </div>
                    <h5 class="fw-bold"><%= t('home.guides.guide2_title') %></h5>
                    <p class="text-muted small"><%= t('home.guides.guide2_desc') %></p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="guide-card">
                    <div class="guide-img">
                        <img src="/img/guide-3.jpeg" alt="Logo Design">
                    </div>
                    <h5 class="fw-bold"><%= t('home.guides.guide3_title') %></h5>
                    <p class="text-muted small"><%= t('home.guides.guide3_desc') %></p>
                </div>
            </div>
        </div>
    </div>
</section>

    <!-- Skills -->
<section class="skills-section">
    <div class="container">
        <h3 class="fw-bold mb-4"><%= t('home.skills.title') %></h3>
        <p class="text-muted mb-5"><%= t('home.skills.subtitle') %></p>

        <div class="row g-3">
            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#003912;">
                    <img src="/img/Web Sitesi Geliştirme.jpeg" alt="Website Development">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.website_dev') %></div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#ff7300;">
                    <img src="/img/Logo Tasarımı.jpeg" alt="Logo Design">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.logo_design') %></div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#00732e;">
                    <img src="/img/SEO.jpeg" alt="SEO">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.seo') %></div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#be5272;">
                    <img src="/img/Mimari & İç Tasarım.jpeg" alt="Architecture">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.architecture') %></div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#f74040;">
                    <img src="/img/Sosyal Medya Pazarlaması.jpeg" alt="Social Media">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.social_media') %></div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <div class="skill-card" style="background-color:#404145;">
                    <img src="/img/Seslendirme.jpeg" alt="Voice Over">
                    <div class="skill-overlay">
                        <div class="skill-title"><%= t('home.skills.voice_over') %></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a href="#" class="btn btn-fiverr"><%= t('home.skills.explore_more') %></a>
        </div>
    </div>
</section>


    <!-- CTA -->
    <section class="cta-section">
        <div class="container">
            <h2 class="fw-bold mb-4"><%= t('home.cta.title') %></h2>
            <a href="#" class="btn btn-fiverr btn-lg"><%= t('home.cta.button') %></a>
        </div>
    </section>
    
</div>

<%- include('includes/footer') %>
