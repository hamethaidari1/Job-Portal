<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Post a New Job</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    
    <nav class="navbar navbar-dark bg-success mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">JobPortal</a>
            <a href="/" class="btn btn-outline-light btn-sm">Back to Home</a>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow p-4 mx-auto" style="max-width: 600px;">
            <h3 class="text-center mb-4">Post a New Job</h3>
            
            <form action="/jobs/create" method="POST">
                <div class="mb-3">
                    <label>Job Title</label>
                    <input type="text" name="title" class="form-control" required placeholder="e.g. Senior Developer">
                </div>
                <div class="mb-3">
                    <label>Company Name</label>
                    <input type="text" name="companyName" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>Location</label>
                    <input type="text" name="location" class="form-control" required placeholder="e.g. Istanbul / Remote">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Job Type</label>
                        <select name="jobType" class="form-select">
                            <option value="Full-time">Full-time</option>
                            <option value="Part-time">Part-time</option>
                            <option value="Remote">Remote</option>
                            <option value="Freelance">Freelance</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>Salary (Optional)</label>
                        <input type="text" name="salary" class="form-control" placeholder="e.g. $3000/month">
                    </div>
                </div>
                <div class="mb-3">
                    <label>Description</label>
                    <textarea name="description" class="form-control" rows="5" required></textarea>
                </div>

                <button type="submit" class="btn btn-success w-100">Post Job</button>
            </form>
        </div>
    </div>

</body>
</html>