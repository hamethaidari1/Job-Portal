<%- include('../includes/header') %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">My Job Listings</h2>
        <a href="/jobs/create" class="btn btn-success">Post New Job</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Job Title</th>
                        <th>Location</th>
                        <th>Posted Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (jobs.length > 0) { %>
                        <% jobs.forEach(job => { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if (job.companyLogo) { %>
                                            <img src="/uploads/<%= job.companyLogo %>" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                        <% } %>
                                        <span class="fw-bold"><%= job.title %></span>
                                    </div>
                                </td>
                                <td><%= job.location %></td>
                                <td><%= new Date(job.createdAt).toLocaleDateString() %></td>
                                <td class="text-center">
                                    <a href="/jobs/<%= job.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                    <a href="/jobs/edit/<%= job.id %>" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                    <form action="/jobs/delete/<%= job.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this job?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">You haven't posted any jobs yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../includes/footer') %>