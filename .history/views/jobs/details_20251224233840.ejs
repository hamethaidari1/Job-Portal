<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">JobPortal</a>
            <div class="d-flex">
                <a href="/" class="btn btn-outline-light btn-sm">Back to Jobs</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="mb-0 text-success"><%= job.title %></h2>
                    <span class="badge bg-secondary fs-6"><%= job.jobType %></span>
                </div>
                <p class="text-muted mb-0 mt-2">
                    <strong>Company:</strong> <%= job.companyName %> | 
                    <strong>Location:</strong> <%= job.location %>
                </p>
            </div>
            <div class="card-body p-4">
                <h5 class="mb-3">Job Description</h5>
                <p class="card-text" style="white-space: pre-line;"><%= job.description %></p>
                
                <hr>
                
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div>
                        <% if (job.salary) { %>
                            <strong>Salary:</strong> <%= job.salary %>
                        <% } %>
                    </div>

                    <% if (isAuthenticated) { %>
                        <button class="btn btn-success btn-lg px-5">Apply Now</button>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-warning">Login to Apply</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

</body>
</html>