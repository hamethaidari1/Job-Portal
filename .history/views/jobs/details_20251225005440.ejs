<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
        <div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">Jobs</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= job.title %></li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px;">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light p-3 rounded-3 me-3">
                        <i class="bi bi-briefcase-fill text-success fs-1"></i>
                    </div>
                    <div>
                        <h1 class="fw-bold mb-1"><%= job.title %></h1>
                        <p class="text-muted mb-0"><i class="bi bi-building me-1"></i> <%= job.companyName %></p>
                    </div>
                </div>

                <hr class="text-muted opacity-25">

                <h4 class="fw-bold mt-4 mb-3">Job Description</h4>
                <div class="job-description text-secondary lh-lg">
                    <%- job.description.replace(/\n/g, '<br>') %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 sticky-top" style="border-radius: 15px; top: 20px;">
                <h5 class="fw-bold mb-4">Job Overview</h5>
                
                <div class="mb-3 d-flex align-items-center">
                    <i class="bi bi-geo-alt text-danger me-3 fs-4"></i>
                    <div>
                        <small class="text-muted d-block">Location</small>
                        <strong><%= job.location %></strong>
                    </div>
                </div>

                <div class="mb-3 d-flex align-items-center">
                    <i class="bi bi-clock text-primary me-3 fs-4"></i>
                    <div>
                        <small class="text-muted d-block">Job Type</small>
                        <strong><%= job.jobType %></strong>
                    </div>
                </div>

                <div class="mb-4 d-flex align-items-center">
                    <i class="bi bi-currency-dollar text-warning me-3 fs-4"></i>
                    <div>
                        <small class="text-muted d-block">Offered Salary</small>
                        <strong><%= job.salary || 'Negotiable' %></strong>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-success btn-lg fw-bold py-3 shadow-sm">Apply Now</button>
                    <button class="btn btn-outline-secondary">Save Job</button>
                </div>

                <div class="mt-4 pt-3 border-top text-center">
                    <p class="small text-muted mb-0">Share this job with friends</p>
                    <div class="mt-2">
                        <i class="bi bi-facebook me-2 cursor-pointer"></i>
                        <i class="bi bi-twitter me-2 cursor-pointer"></i>
                        <i class="bi bi-linkedin cursor-pointer"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>