<div class="container-fluid bg-light py-5" style="min-height: 100vh;">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <a href="/" class="btn btn-sm btn-outline-secondary shadow-sm bg-white">
                <i class="bi bi-arrow-left"></i> Back to Jobs
            </a>
        </nav>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
                                <i class="bi bi-briefcase-fill text-success fs-1"></i>
                            </div>
                            <div>
                                <h1 class="fw-bold mb-1 text-dark"><%= job.title %></h1>
                                <p class="text-muted fs-5 mb-0"><i class="bi bi-building me-1"></i> <%= job.companyName %></p>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <h4 class="fw-bold mb-3 text-success">Job Description</h4>
                        <div class="job-description text-dark lh-lg fs-6" style="text-align: justify;">
                            <%- job.description.replace(/\n/g, '<br>') %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="border-radius: 15px; top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Job Overview</h5>
                        
                        <div class="mb-4 d-flex align-items-start">
                            <i class="bi bi-geo-alt text-danger me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Location</small>
                                <span class="fw-bold text-dark"><%= job.location %></span>
                            </div>
                        </div>

                        <div class="mb-4 d-flex align-items-start">
                            <i class="bi bi-clock text-primary me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Job Type</small>
                                <span class="fw-bold text-dark"><%= job.jobType %></span>
                            </div>
                        </div>

                        <div class="mb-4 d-flex align-items-start">
                            <i class="bi bi-currency-dollar text-warning me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Offered Salary</small>
                                <span class="fw-bold text-dark"><%= job.salary || 'Negotiable' %></span>
                            </div>
                        </div>

                        <div class="d-grid gap-3 mt-5">
                            <button class="btn btn-success btn-lg fw-bold py-3 shadow-sm border-0">
                                <i class="bi bi-send-fill me-2"></i> Apply Now
                            </button>
                            <button class="btn btn-outline-secondary py-2">
                                <i class="bi bi-bookmark me-2"></i> Save Job
                            </button>
                        </div>

                        <div class="mt-4 pt-3 border-top text-center">
                            <p class="small text-muted mb-2">Share this job</p>
                            <div class="d-flex justify-content-center gap-3">
                                <a href="#" class="text-secondary fs-4"><i class="bi bi-linkedin"></i></a>
                                <a href="#" class="text-secondary fs-4"><i class="bi bi-facebook"></i></a>
                                <a href="#" class="text-secondary fs-4"><i class="bi bi-twitter-x"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>