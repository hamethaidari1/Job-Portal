<%- include('../includes/header.ejs') %>

<%- include('../includes/footer.ejs') %>
<div class="container-fluid bg-light py-5" style="min-height: 100vh;">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <a href="/" class="btn btn-sm btn-white shadow-sm border px-3" style="border-radius: 20px; text-decoration: none; color: #333; background: white;">
                <i class="bi bi-arrow-left me-1"></i> Back to Jobs
            </a>
        </nav>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
                                <i class="bi bi-briefcase-fill text-success fs-1"></i>
                            </div>
                            <div>
                                <h1 class="fw-bold mb-1 text-dark"><%= job.title %></h1>
                                <p class="text-muted mb-0">At <span class="fw-bold text-success"><%= job.companyName %></span></p>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <h4 class="fw-bold mb-3 text-success">Job Description</h4>
                        <div class="text-dark lh-lg fs-6">
                            <%- job.description.replace(/\n/g, '<br>') %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="border-radius: 15px; top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Job Overview</h5>
                        
                        <div class="mb-3 d-flex align-items-center">
                            <i class="bi bi-geo-alt text-danger me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Location</small>
                                <strong class="text-dark"><%= job.location %></strong>
                            </div>
                        </div>

                        <div class="mb-3 d-flex align-items-center">
                            <i class="bi bi-clock text-primary me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Job Type</small>
                                <strong class="text-dark"><%= job.jobType %></strong>
                            </div>
                        </div>

                        <div class="mb-4 d-flex align-items-center">
                            <i class="bi bi-cash-stack text-success me-3 fs-4"></i>
                            <div>
                                <small class="text-muted d-block">Salary</small>
                                <strong class="text-dark">$<%= job.salary %></strong>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn btn-success btn-lg fw-bold shadow-sm py-3" style="border-radius: 10px;">Apply Now</button>
                            <button class="btn btn-outline-secondary py-2" style="border-radius: 10px;">Save Job</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../includes/footer') %>