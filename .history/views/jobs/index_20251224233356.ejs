<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Available Jobs</h2>
        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/jobs/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Post New Job</a>
        <% } %>
    </div>

    <div class="card bg-light mb-4 shadow-sm">
        <div class="card-body">
            <form action="/jobs" method="GET" class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="search" class="form-control" placeholder="Search by job title, company, or location..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="row">
        <% if (jobs.length > 0) { %>
            <% jobs.forEach(job => { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title text-primary fw-bold"><%= job.title %></h5>
                                <span class="badge bg-info text-dark" style="height: fit-content;"><%= job.jobType %></span>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted"><%= job.companyName %></h6>
                            <p class="card-text text-secondary">
                                <i class="bi bi-geo-alt-fill text-danger"></i> <%= job.location %>
                            </p>
                           <a href="#" class="btn btn-sm btn-outline-success float-end">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <% if (typeof searchTerm !== 'undefined' && searchTerm) { %>
                    <div class="alert alert-warning">
                        No jobs found matching "<strong><%= searchTerm %></strong>". <br>
                        <a href="/jobs" class="mt-2 d-inline-block">View all jobs</a>
                    </div>
                <% } else { %>
                    <div class="text-muted">
                        <i class="bi bi-folder-x display-1"></i>
                        <h4 class="mt-3">No jobs posted yet.</h4>
                        <p>Be the first one to post a job!</p>
                        <% if (typeof user !== 'undefined' && user) { %>
                            <a href="/jobs/create" class="btn btn-primary mt-2">Post a Job</a>
                        <% } else { %>
                            <a href="/auth/login" class="btn btn-primary mt-2">Login to Post a Job</a>
                        <% } %>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>