<div class="bg-success text-white py-5 mb-5 shadow-sm">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Find Your Dream Job</h1>
        <p class="lead">Browse thousands of job opportunities or post your own.</p>
    </div>
</div>

<div class="container">
    <div class="row">
        <% if (jobs.length > 0) { %>
            <% jobs.forEach(job => { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.2s;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-success"><%= job.title %></h5>
                                <span class="badge bg-light text-success border border-success"><%= job.jobType %></span>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted">
                                <i class="bi bi-building me-1"></i> <%= job.companyName %>
                            </h6>
                            <p class="card-text text-secondary small text-truncate-3">
                                <%= job.description.substring(0, 100) %>...
                            </p>
                            <div class="d-flex align-items-center mb-3 small text-muted">
                                <span class="me-3"><i class="bi bi-geo-alt me-1"></i> <%= job.location %></span>
                                <span><i class="bi bi-cash-stack me-1"></i> <%= job.salary || 'Negotiable' %></span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-4">
                            <a href="/jobs/<%= job.id %>" class="btn btn-outline-success w-100 fw-bold">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <i class="bi bi-search display-1 text-muted"></i>
                <h3 class="mt-3">No jobs found!</h3>
                <p class="text-muted">Be the first to <a href="/jobs/create" class="text-success">post a job</a>.</p>
            </div>
        <% } %>
    </div>
</div>

<style>
    .card:hover { transform: translateY(-5px); }
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>