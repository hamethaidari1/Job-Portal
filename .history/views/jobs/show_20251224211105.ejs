<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-lg">
                <div class="card-header bg-white p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 text-primary"><%= job.title %></h2>
                        <span class="badge bg-success fs-6"><%= job.jobType %></span>
                    </div>
                    <h5 class="text-muted mt-2"><%= job.companyName %></h5>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt-fill"></i> <%= job.location %> | 
                        <i class="bi bi-cash-stack"></i> <%= job.salary || 'Negotiable' %>
                    </p>
                </div>
                
                <div class="card-body p-4">
                    <h5 class="fw-bold">Job Description</h5>
                    <p class="card-text" style="white-space: pre-line;"><%= job.description %></p>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex gap-2">
                        <a href="mailto:HR@example.com?subject=Application for <%= job.title %>" class="btn btn-primary btn-lg">Apply Now</a>
                        <a href="/jobs" class="btn btn-outline-secondary btn-lg">Back to Jobs</a>
                    </div>
                </div>
                
                <div class="card-footer text-muted text-center">
                    Posted on <%= new Date(job.createdAt).toLocaleDateString() %>
                </div>
            </div>
        </div>
    </div>
</div>