<style>
    /* دکمه سوئیچ کپسولی مشابه تصویر */
    .toggle-pill-wrapper {
        background: #fff;
        border: 1px solid #e4e5e7;
        border-radius: 50px;
        padding: 5px;
        display: inline-flex;
    }
    .pill-btn {
        border: none;
        background: none;
        padding: 8px 24px;
        border-radius: 50px;
        font-weight: 700;
        color: #74767e;
        transition: all 0.3s ease;
        font-size: 15px;
    }
    .pill-btn.active {
        background-color: #000000;
        color: #ffffff;
    }

    /* استایل کارت‌های ویدیو */
    .modern-video-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #efeff0;
        height: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .modern-video-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }
    .video-container {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: #000;
        overflow: hidden;
    }
    .video-container video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .card-body-custom {
        padding: 20px;
    }
    .card-body-custom h6 {
        font-weight: 700;
        color: #404145;
        margin-bottom: 10px;
        font-size: 1.1rem;
    }
    .card-body-custom p {
        color: #62646a;
        font-size: 14px;
        line-height: 1.5;
        margin: 0;
    }

    /* انیمیشن محو شدن */
    .fade-in-custom {
        animation: fadeIn 0.5s forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    function switchWorkTab(type) {
        const hiringSteps = document.getElementById('hiring-steps');
        const findingSteps = document.getElementById('finding-steps');
        const btnHiring = document.getElementById('btn-hiring');
        const btnFinding = document.getElementById('btn-finding');

        if (type === 'hiring') {
            hiringSteps.classList.remove('d-none');
            hiringSteps.classList.add('fade-in-custom');
            findingSteps.classList.add('d-none');
            
            btnHiring.classList.add('active');
            btnFinding.classList.remove('active');
        } else {
            findingSteps.classList.remove('d-none');
            findingSteps.classList.add('fade-in-custom');
            hiringSteps.classList.add('d-none');
            
            btnFinding.classList.add('active');
            btnHiring.classList.remove('active');
        }
    }
</script>