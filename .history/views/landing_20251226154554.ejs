<%- include('includes/header') %>

<style>
    .landing-hero {
        background-color: #183823; 
        color: white; 
        /* درازی خورد شده: پدینگ از 80px به 50px و از 120px به 70px کاهش یافت */
        padding: 25px 0 15px; 
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        min-height: 400px; /* حداقل ارتفاع برای حفظ زیبایی */
    }
    
    .landing-hero::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('https://placehold.co/1920x600/023a15/055220?text=İŞBUL+ONLINE') center/cover;
        opacity: 0.1;
    }

    .landing-content {
        position: relative;
        z-index: 1;
    }

    /* کوچک کردن اندازه متن تیتر برای هماهنگی با ارتفاع جدید */
    .landing-hero h1 {
        font-size: 2.8rem; 
        margin-bottom: 20px;
    }

    .feature-icon-box {
        width: 70px; /* اندکی کوچکتر */
        height: 70px;
        background-color: #f4fdf7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        color: #1dbf73;
        font-size: 1.8rem;
        transition: transform 0.3s;
    }

    .feature-card:hover .feature-icon-box {
        transform: scale(1.1);
        background-color: #1dbf73;
        color: white;
    }
</style>

<div class="landing-hero">
    <div class="container landing-content text-center">
        <h1 class="display-3 fw-bold mb-4"><%- t('landing.hero_title') %></h1>
        <p class="lead mb-5 opacity-75" style="max-width: 700px; margin: 0 auto;">
            <%= t('landing.hero_subtitle') %>
        </p>
        
        <div class="search-bar-container mb-5">
            <form action="/jobs/search" method="GET" class="d-flex justify-content-center gap-2">
                <input type="text" name="q" class="form-control form-control-lg" style="max-width: 400px;" placeholder="<%= t('Bugün hangi hizmeti arıyorsunuz?') %>">
                <button type="submit" class="btn btn-success btn-lg"><%= t('common.search') %></button>
            </form>
        </div>
        
        <div class="d-flex justify-content-center gap-3 mb-5">
            <a href="/auth/register" class="btn btn-success btn-lg px-5 py-3 fw-bold shadow-sm"><%= t('landing.join_button') %></a>
            <a href="/auth/login" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold"><%= t('common.login') %></a>
        </div>
    </div>
</div>

<!-- HOW IT WORKS SECTION -->
<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-3 mb-md-0">How it works</h2>
        
        <div class="toggle-container">
            <button class="toggle-btn active" onclick="switchTab('hiring')">For hiring</button>
            <button class="toggle-btn" onclick="switchTab('finding')">For finding work</button>
        </div>
    </div>

    <!-- HIRING CONTENT -->
    <div id="hiring-content" class="row g-4">
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/hiring1.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Post a job and find talent</h5>
                <p class="text-muted small">Create a job post and start receiving proposals from top freelancers.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/hiring2.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Review proposals</h5>
                <p class="text-muted small">Compare bids, reviews, and portfolios to find the perfect fit.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/hiring3.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Hire and get work done</h5>
                <p class="text-muted small">Collaborate securely and release payment only when satisfied.</p>
            </div>
        </div>
    </div>

    <!-- FINDING WORK CONTENT -->
    <div id="finding-content" class="row g-4" style="display: none;">
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/finding1.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Create your profile</h5>
                <p class="text-muted small">Showcase your skills and portfolio to attract potential clients.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/finding2.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Search for jobs</h5>
                <p class="text-muted small">Find projects that match your expertise and apply with a proposal.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video controls>
                    <source src="/video/finding3.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
                <h5>Get paid securely</h5>
                <p class="text-muted small">Deliver high-quality work and receive payments on time.</p>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        const hiringContent = document.getElementById('hiring-content');
        const findingContent = document.getElementById('finding-content');
        const buttons = document.querySelectorAll('.toggle-btn');
        
        if (tab === 'hiring') {
            hiringContent.style.display = 'flex';
            findingContent.style.display = 'none';
            buttons[0].classList.add('active');
            buttons[1].classList.remove('active');
        } else {
            hiringContent.style.display = 'none';
            findingContent.style.display = 'flex';
            buttons[0].classList.remove('active');
            buttons[1].classList.add('active');
        }
    }
</script>

