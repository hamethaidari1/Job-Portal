<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">JobPortal</a>
            
            <div class="d-flex align-items-center">
                <select id="langSelect" class="form-select form-select-sm me-3" style="width: 100px;">
                    <option value="tr" <%= (typeof lang !== 'undefined' && lang === 'tr') ? 'selected' : '' %>>🇹🇷 TR</option>
                    <option value="en" <%= (typeof lang !== 'undefined' && lang === 'en') ? 'selected' : '' %>>🇬🇧 EN</option>
                </select>

                <% if (user) { %> 
                    <span class="text-white me-3"><%= user.email %></span>
                    <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                        <%= (typeof t !== 'undefined') ? t.logout : 'Logout' %>
                    </a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-light btn-sm me-2">
                        <%= (typeof t !== 'undefined') ? t.login : 'Login' %>
                    </a>
                    <a href="/auth/register" class="btn btn-outline-light btn-sm">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <%- body %>
    </div>

    <script src="/js/main.js"></script>
    </body>
</html>