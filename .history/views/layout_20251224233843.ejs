<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">JobPortal</a>
            
            <div class="d-flex align-items-center">
                <select id="langSelect" class="form-select form-select-sm me-3" style="width: 100px;">
                    <option value="tr" <%= lang === 'tr' ? 'selected' : '' %>>🇹🇷 TR</option>
                    <option value="en" <%= lang === 'en' ? 'selected' : '' %>>🇬🇧 EN</option>
                </select>

                <% if (typeof user !== 'undefined') { %>
                    <span class="text-white me-3"><%= user.email %></span>
                    <a href="/auth/logout" class="btn btn-outline-light btn-sm"><%= t.logout %></a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-light btn-sm me-2"><%= t.login %></a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <%- body %>
    </div>

    <script src="/js/main.js"></script>
    <script type="module" src="/js/firebase-config.js"></script>
</body>
</html>