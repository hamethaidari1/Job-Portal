<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-briefcase-fill"></i> JobPortal
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto align-items-center">
                    
                    <select id="langSelect" class="form-select form-select-sm me-3 bg-light border-0" style="width: 110px; cursor: pointer;">
                        <option value="tr" <%= typeof lang !== 'undefined' && lang === 'tr' ? 'selected' : '' %>>🇹🇷 TR</option>
                        <option value="en" <%= typeof lang !== 'undefined' && lang === 'en' ? 'selected' : '' %>>🇬🇧 EN</option>
                    </select>

                    <% if (typeof user !== 'undefined' && user) { %>
                        <span class="text-white me-3 d-none d-lg-block">
                            <i class="bi bi-person-circle"></i> <%= user.email %>
                        </span>
                        <a href="/jobs/create" class="btn btn-light btn-sm me-2 text-success fw-bold">
                            <i class="bi bi-plus-lg"></i> Post Job
                        </a>
                        <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                            <%= typeof t !== 'undefined' ? t.logout : 'Logout' %>
                        </a>
                    <% } else { %>
                        <a href="/auth/login" class="nav-link text-white me-2">
                            <%= typeof t !== 'undefined' ? t.login : 'Login' %>
                        </a>
                        <a href="/auth/register" class="btn btn-outline-light btn-sm">Register</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-4 flex-grow-1">
        <%- body %>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <div class="container">
            <p class="mb-0 small">&copy; 2025 JobPortal System. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script type="module" src="/js/firebase-config.js"></script>
</body>
</html>