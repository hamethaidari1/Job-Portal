<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | JobPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f7f7f7; }
        
        /* استایل اختصاصی Navbar شبیه Fiverr */
        .navbar {
            background-color: #fff;
            border-bottom: 1px solid #e4e5e7;
            padding: 15px 0;
        }
        .navbar-brand {
            font-weight: 900;
            font-size: 28px;
            color: #404145;
            letter-spacing: -1px;
        }
        .navbar-brand span { color: #1dbf73; } /* نقطه سبز فایور */
        
        .nav-link {
            color: #62646a;
            font-weight: 600;
            font-size: 15px;
            margin: 0 10px;
        }
        .nav-link:hover { color: #1dbf73; }
        
        .btn-join {
            border: 1px solid #1dbf73;
            color: #1dbf73;
            font-weight: 600;
            padding: 6px 20px;
            border-radius: 4px;
            transition: all 0.3s;
        }
        .btn-join:hover {
            background-color: #1dbf73;
            color: white;
        }
        
        .user-avatar {
            width: 35px;
            height: 35px;
            background-color: #1dbf73;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <form action="/" method="GET" class="ms-lg-3 d-none d-xl-flex">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control" placeholder="Find Services..." style="width: 250px;">
                    <button class="btn btn-dark" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/">Explore</a>
                </li>
                
                <% if (isAuthenticated) { %>
                    <li class="nav-item">
                        <a class="nav-link text-success" href="/jobs/create">Post a Job</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/jobs/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link p-0 ms-2" href="#" id="userDrop" data-bs-toggle="dropdown">
                            <div class="user-avatar text-uppercase">
                                <%= user.username.charAt(0) %>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li><a class="dropdown-item small" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/login">Sign In</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn-join ms-lg-2" href="/auth/register">Join</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>