<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* این استایل تضمین می‌کند که نوار ناوبری همیشه در بالاترین لایه باشد */
        .fiverr-nav {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            width: 100% !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            z-index: 999999 !important; /* عدد بسیار بزرگ برای اولویت */
            height: 80px !important;
            display: flex !important;
            align-items: center !important;
        }
        body { padding-top: 80px !important; margin: 0; font-family: 'Inter', sans-serif; }
    </style>
</head>
<body>

<nav class="fiverr-nav shadow-sm">
    <div class="container d-flex justify-content-between align-items-center">
        <a href="/" style="font-weight: 900; font-size: 28px; color: #404145; text-decoration: none;">
            jobportal<span style="color: #1dbf73;">.</span>
        </a>
        
        <div class="d-flex align-items-center">
            <a href="/" style="color: #62646a; font-weight: 600; text-decoration: none; margin: 0 15px;">Explore</a>
            <% if (isAuthenticated) { %>
                <a href="/jobs/create" style="color: #1dbf73; font-weight: 600; text-decoration: none; margin: 0 15px;">Post a Job</a>
                <a href="/jobs/dashboard" style="color: #62646a; font-weight: 600; text-decoration: none; margin: 0 15px;">Dashboard</a>
                <a href="/auth/logout" class="btn btn-sm btn-outline-danger ms-2">Logout</a>
            <% } else { %>
                <a href="/auth/login" style="color: #62646a; font-weight: 600; text-decoration: none; margin: 0 15px;">Sign In</a>
                <a href="/auth/register" class="btn btn-outline-success fw-bold ms-2" style="border-color: #1dbf73; color: #1dbf73;">Join</a>
            <% } %>
        </div>
    </div>
</nav>