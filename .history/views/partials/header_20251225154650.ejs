<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | JobPortal</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { margin: 0; padding: 0; background-color: #f7f7f7; }

        /* استایل اصلی نوار ناوبری */
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            position: fixed !important;
            top: 0;
            width: 100%;
            z-index: 99999 !important; /* بالاترین لایه ممکن */
            height: 80px;
            display: flex;
            align-items: center;
        }

        /* اجبار به دیده شدن متن‌ها */
        .navbar-brand, .navbar-brand span, .nav-link, .bi-search {
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
        }

        .navbar-brand {
            font-weight: 900;
            font-size: 26px;
            color: #404145 !important;
            text-decoration: none;
        }
        .navbar-brand span { color: #1dbf73 !important; }

        .nav-link {
            color: #62646a !important; /* رنگ خاکستری تیره برای دیده شدن روی سفید */
            font-weight: 600;
            margin: 0 10px;
            text-decoration: none !important;
        }

        .content-wrapper {
            padding-top: 80px !important; /* دقیقاً هم‌اندازه ارتفاع نوار */
        }

        .user-avatar, .user-avatar-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }
        .user-avatar {
            background-color: #1dbf73;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <form action="/" method="GET" class="ms-lg-4 d-flex border rounded bg-light">
                <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Find Services..." style="width: 200px;">
                <button class="btn border-0" type="submit"><i class="bi bi-search text-dark"></i></button>
            </form>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="/">Explore</a></li>
                
                <% if (isAuthenticated) { %>
                    <li class="nav-item"><a class="nav-link text-success" href="/jobs/create">Post a Job</a></li>
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link p-0 ms-lg-3" href="#" id="userDrop" data-bs-toggle="dropdown">
                            <% if (user && user.profileImage) { %>
                                <img src="/uploads/<%= user.profileImage %>" class="user-avatar-img">
                            <% } else { %>
                                <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                            <% } %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li class="p-2 text-center fw-bold border-bottom"><%= user.username %></li>
                            <li><a class="dropdown-item mt-2" href="/auth/logout text-danger">Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login">Sign In</a></li>
                    <li class="nav-item"><a class="btn btn-outline-success ms-lg-2 fw-bold" href="/auth/register" style="border-radius: 4px;">Join</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="content-wrapper">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>