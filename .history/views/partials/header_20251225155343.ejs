<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'JobPortal' %></title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { margin: 0; padding: 0; background-color: #f7f7f7; }
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            position: fixed !important;
            top: 0; width: 100%; height: 80px;
            z-index: 10000 !important;
            display: flex; align-items: center;
        }
        .navbar-brand { font-weight: 900; font-size: 26px; color: #404145 !important; text-decoration: none; }
        .navbar-brand span { color: #1dbf73 !important; }
        .nav-link { color: #62646a !important; font-weight: 600; text-decoration: none !important; }
        .content-wrapper { padding-top: 80px !important; } /* این لایه بسیار مهم است */
        .user-avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background-color: #1dbf73; color: white;
            display: flex; align-items: center; justify-content: center; font-weight: bold;
        }
        .user-avatar-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 1px solid #1dbf73; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <form action="/" method="GET" class="ms-lg-4 d-flex border rounded bg-light">
                <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Find Services..." style="width: 200px;">
                <button class="btn border-0" type="submit"><i class="bi bi-search text-dark"></i></button>
            </form>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="/">Explore</a></li>
                
                <% if (isAuthenticated) { %>
                    <li class="nav-item"><a class="nav-link text-success" href="/jobs/create">Post a Job</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link p-0 ms-lg-3" href="#" id="userDrop" data-bs-toggle="dropdown" aria-expanded="false">
                            <% if (user && user.profileImage) { %>
                                <img src="/uploads/<%= user.profileImage %>" class="user-avatar-img">
                            <% } else { %>
                                <div class="user-avatar"><%= user && user.username ? user.username.charAt(0).toUpperCase() : 'U' %></div>
                            <% } %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li class="p-2 text-center fw-bold border-bottom"><%= user ? user.username : 'User' %></li>
                            <li><a class="dropdown-item mt-2 text-danger" href="/auth/logout">Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login">Sign In</a></li>
                    <li class="nav-item"><a class="btn btn-outline-success ms-lg-2 fw-bold" href="/auth/register">Join</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="content-wrapper"> ```

