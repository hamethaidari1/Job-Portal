<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'JobPortal' %></title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* استایل اختصاصی برای دیده شدن نوار ناوبری */
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            position: fixed !important; /* ثابت ماندن در بالا */
            top: 0;
            left: 0;
            width: 100%;
            height: 80px;
            z-index: 10000 !important; /* بالاترین لایه برای دیده شدن روی بخش سبز */
            display: flex;
            align-items: center;
        }

        .navbar-brand {
            font-weight: 900;
            font-size: 26px;
            color: #404145 !important;
        }
        .navbar-brand span { color: #1dbf73 !important; }

        .nav-link {
            color: #62646a !important;
            font-weight: 600;
        }

        /* این کلاس باعث می‌شود محتوای صفحه زیر نوار ناوبری نرود */
        .main-content-wrapper {
            margin-top: 80px !important;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <form action="/" method="GET" class="ms-lg-4 d-flex border rounded bg-light p-1" style="min-width: 250px;">
                <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Find Services...">
                <button class="btn border-0" type="submit"><i class="bi bi-search text-muted"></i></button>
            </form>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="/">Explore</a></li>
                
                <% if (isAuthenticated) { %>
                    <li class="nav-item"><a class="nav-link text-success fw-bold" href="/jobs/create">Post a Job</a></li>
                    <li class="nav-item ms-lg-3">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; font-weight: bold;">
                            <%= user ? user.username.charAt(0).toUpperCase() : 'U' %>
                        </div>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login">Sign In</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-success ms-lg-2 fw-bold px-4" href="/auth/register" style="border-radius: 4px;">Join</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="main-content-wrapper">