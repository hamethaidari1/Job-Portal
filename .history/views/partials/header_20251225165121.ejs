<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { margin: 0; padding: 0; }
        
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            position: fixed !important;
            top: 0;
            width: 100%;
            height: 80px;
            z-index: 10000 !important;
            display: flex !important;
            align-items: center;
        }

        /* اجبار به رنگ تیره برای دیده شدن روی نوار سفید */
        .navbar-brand {
            color: #404145 !important;
            font-weight: 900;
            font-size: 26px;
            text-decoration: none;
        }
        .navbar-brand span { color: #1dbf73 !important; }

        .nav-link {
            color: #62646a !important; /* خاکستری تیره */
            font-weight: 600;
        }

        .main-wrapper {
            margin-top: 80px !important; /* ایجاد فاصله برای بخش سبز */
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>
        
        <div class="collapse navbar-collapse d-flex justify-content-between">
            <form action="/" method="GET" class="ms-4 d-flex border rounded bg-light" style="width: 300px;">
                <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Find Services...">
                <button class="btn border-0" type="submit"><i class="bi bi-search text-dark"></i></button>
            </form>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link px-3" href="/">Explore</a></li>
                
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <li class="nav-item"><a class="nav-link text-success fw-bold" href="/jobs/create">Post a Job</a></li>
                    <li class="nav-item ms-3">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <%= user ? user.username.charAt(0).toUpperCase() : 'U' %>
                        </div>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link px-3" href="/auth/login">Sign In</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-success ms-2 fw-bold" href="/auth/register">Join</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="main-wrapper">