<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Portal</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* استایل نوار ناوبری */
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 2px solid #e4e5e7 !important;
            position: fixed !important;
            top: 0;
            width: 100%;
            height: 80px;
            z-index: 10000 !important;
            display: flex !important; /* اطمینان از نمایش */
        }

        /* اجبار به رنگ تیره برای لوگو و لینک‌ها */
        .navbar-brand {
            color: #222325 !important; 
            font-weight: 900 !important;
            font-size: 26px !important;
            display: block !important;
            visibility: visible !important;
        }
        .navbar-brand span { color: #1dbf73 !important; }

        .nav-link {
            color: #404145 !important; /* رنگ خاکستری تیره */
            font-weight: 700 !important;
            visibility: visible !important;
        }

        /* فاصله برای بخش سبز */
        .main-container {
            margin-top: 80px !important;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container d-flex align-items-center justify-content-between">
        
        <a class="navbar-brand" href="/">jobportal<span>.</span></a>

        <div class="d-flex align-items-center">
            <ul class="navbar-nav flex-row align-items-center">
                <li class="nav-item px-3"><a class="nav-link" href="/">Explore</a></li>
                
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <li class="nav-item px-2"><a class="nav-link text-success" href="/jobs/create">Post Job</a></li>
                    <li class="nav-item">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <%= user ? user.username.charAt(0).toUpperCase() : 'U' %>
                        </div>
                    </li>
                <% } else { %>
                    <li class="nav-item px-3"><a class="nav-link" href="/auth/login">Sign In</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-success fw-bold px-4" href="/auth/register" style="border-radius: 4px; border: 1px solid #1dbf73;">Join</a>
                    </li>
                <% } %>
            </ul>
        </div>

    </div>
</nav>

<div class="main-container">