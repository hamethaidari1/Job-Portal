<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* استایل پایه برای نوار ناوبری فایور */
        .fiverr-header {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7;
            height: 80px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 99999;
            display: flex;
            align-items: center;
        }

        .f-logo {
            font-weight: 900;
            font-size: 30px;
            color: #000000 !important;
            text-decoration: none;
            margin-right: 20px;
        }

        .f-logo span { color: #1dbf73; }

        .f-search {
            border: 1px solid #b5b6ba;
            border-radius: 4px;
            display: flex;
            flex: 1;
            max-width: 400px;
        }

        .f-nav-links {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            align-items: center;
        }

        .f-nav-links li a {
            color: #62646a;
            text-decoration: none;
            font-weight: 600;
            padding: 0 15px;
        }

        .btn-join {
            border: 1px solid #1dbf73;
            color: #1dbf73 !important;
            padding: 5px 20px !important;
            border-radius: 4px;
        }

        /* این برای جلوگیری از مخفی شدن محتوای سبز */
        .push-content { margin-top: 80px; }
    </style>
</head>
<body>

<header class="fiverr-header">
    <div class="container d-flex align-items-center justify-content-between">
        
        <div class="d-flex align-items-center flex-grow-1">
            <a href="/" class="f-logo">fiverr<span>.</span></a>

            <div class="f-search d-none d-md-flex">
                <input type="text" class="form-control border-0 shadow-none" placeholder="What service are you looking for?">
                <button class="btn btn-dark" style="border-radius: 0 3px 3px 0;">Search</button>
            </div>
        </div>

        <nav>
            <ul class="f-nav-links">
                <li><a href="/">Explore</a></li>
                <li><a href="/auth/login">Sign In</a></li>
                <li><a href="/auth/register" class="btn-join">Join</a></li>
            </ul>
        </nav>

    </div>
</header>

<div class="push-content">