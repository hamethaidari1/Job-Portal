<!DOCTYPE html>
<html lang="fa" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* استایل اختصاصی نوار ناوبری */
        .fiverr-nav {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e4e5e7 !important;
            height: 80px;
            position: fixed !important;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 10000 !important;
            display: flex;
            align-items: center;
        }

        /* لوگوی سیاه مشابه فایور */
        .f-logo {
            font-weight: 900;
            font-size: 30px;
            color: #000000 !important;
            text-decoration: none;
            letter-spacing: -1.5px;
        }
        .f-logo span { color: #1dbf73; }

        /* باکس جستجوی میانی */
        .f-search-box {
            border: 1px solid #b5b6ba;
            border-radius: 4px;
            overflow: hidden;
            width: 100%;
            max-width: 450px;
            margin: 0 20px;
        }

        .f-search-box input {
            border: none;
            padding: 10px 15px;
            outline: none;
            width: 100%;
        }

        .f-search-box button {
            background-color: #222325;
            color: white;
            border: none;
            padding: 0 15px;
        }

        /* لینک‌های سمت راست */
        .f-links {
            list-style: none;
            display: flex;
            margin: 0;
            padding: 0;
            align-items: center;
        }

        .f-links a {
            color: #62646a !important;
            text-decoration: none;
            font-weight: 600;
            padding: 0 15px;
            font-size: 15px;
        }

        .f-links a:hover { color: #1dbf73 !important; }

        /* دکمه Join */
        .f-btn-join {
            border: 1px solid #1dbf73 !important;
            color: #1dbf73 !important;
            border-radius: 4px;
            padding: 5px 20px !important;
            margin-left: 10px;
        }

        .f-btn-join:hover {
            background-color: #1dbf73 !important;
            color: #ffffff !important;
        }

        /* جلوگیری از رفتن محتوا زیر نوار */
        .content-push { margin-top: 80px; }
    </style>
</head>
<body>

<header class="fiverr-nav shadow-sm">
    <div class="container d-flex align-items-center justify-content-between">
        
        <div class="d-flex align-items-center flex-grow-1">
            <a href="/" class="f-logo">fiverr<span>.</span></a>

            <form action="/" method="GET" class="f-search-box d-none d-lg-flex">
                <input type="text" name="search" placeholder="What service are you looking for?">
                <button type="submit"><i class="bi bi-search"></i></button>
            </form>
        </div>

        <nav>
            <ul class="f-links">
                <li class="d-none d-md-block"><a href="/">Explore</a></li>
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <li><a href="/jobs/create" class="text-success">Post Gigs</a></li>
                    <li>
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold ms-2" style="width: 35px; height: 35px;">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                    </li>
                <% } else { %>
                    <li><a href="/auth/login">Sign In</a></li>
                    <li><a href="/auth/register" class="f-btn-join">Join</a></li>
                <% } %>
            </ul>
        </nav>

    </div>
</header>

<div class="content-push">