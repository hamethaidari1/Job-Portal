<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <style>
        footer {
            /* Dark green Fiverr color */
            background-color: #0a4226 !important; 
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #ffffff; /* White text color */
            padding-top: 50px;
        }
        
        footer h5 {
            color: #1dbf73; /* Titles in light green Fiverr color for beautiful contrast */
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 25px;
        }
        
        footer ul li {
            margin-bottom: 12px;
        }
        
        footer ul li a {
            color: rgba(255, 255, 255, 0.8) !important; /* White with slight transparency */
            font-size: 15px;
            text-decoration: none;
            transition: 0.3s;
        }
        
        footer ul li a:hover {
            color: #1dbf73 !important; /* Change color to light green on hover */
            padding-left: 5px;
        }
        
        .footer-bottom {
            padding: 30px 0;
            border-top: 1px solid rgba(255, 255, 255, 0.1); /* Faded separator line */
            margin-top: 40px;
        }
        
        .footer-logo-text {
            font-size: 24px;
            font-weight: 900;
            color: #ffffff;
            letter-spacing: -1px;
        }
        
        .footer-logo-text span {
            color: #3b976c;
        }

        .social-icons a {
            font-size: 20px;
            color: white;
            margin-left: 20px;
            opacity: 0.8;
            transition: 0.3s;
        }
        
        .social-icons a:hover {
            opacity: 1;
            color: #1dbf73;
            transform: translateY(-3px);
            display: inline-block;
        }

        .brand-desc {
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.6;
            font-size: 14px;
        }
    </style>

    <footer class="mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-6 col-md-3 mb-4">
                    <h5><%= t('footer.links_title') %></h5>
                    <ul class="list-unstyled">
                        <li><a href="/jobs"><%= t('footer.about') %></a></li>
                        <li><a href="/help"><%= t('footer.contact') %></a></li>
                        <li><a href="/privacy">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-3 mb-4">
                    <h5><%= t('footer.support_title') %></h5>
                    <ul class="list-unstyled">
                        <li><a href="/help"><%= t('footer.help') %></a></li>
                        <li><a href="/trust"><%= t('footer.trust') %></a></li>
                        <li><a href="/settings">Account Settings</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 mb-4">
                    <div class="footer-logo-text mb-3">İŞBUL<span>.</span>ONLINE</div>
                    <p class="brand-desc">
                        <%= t('footer.brand_desc') %>
                    </p>
                </div>
            </div>

            <div class="footer-bottom d-flex flex-wrap justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <small class="opacity-75">© <%= new Date().getFullYear() %> İşbul Online. All rights reserved.</small>
                </div>
                
                <div class="social-icons d-flex align-items-center mt-3 mt-md-0">
                    <a href="#"><i class="bi bi-tiktok"></i></a>
                    <a href="#"><i class="bi bi-instagram"></i></a>
                    <a href="#"><i class="bi bi-linkedin"></i></a>
                    <a href="#"><i class="bi bi-facebook"></i></a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>