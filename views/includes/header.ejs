<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'tr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Fiverr Clone' %></title>
    <style>
        :root {
            --fiverr-green: #1dbf73;
            --fiverr-dark: #404145;
        }
        
        body {
            padding-top: 140px; /* Adjust for double navbar */
            font-family: "Macan", "Helvetica Neue", Helvetica, Arial, sans-serif;
        }

        /* Top Navbar */
        .navbar-main {
            background-color: #fff;
            border-bottom: 1px solid #e4e5e7;
            padding: 12px 0;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 28px;
            color: #404145;
            letter-spacing: -1px;
        }
        
        .navbar-brand span {
            color: var(--fiverr-green);
        }

        /* Search Bar */
        .header-search {
            max-width: 500px;
            width: 100%;
        }
        
        .header-search .form-control {
            border: 1px solid #c5c6c9;
            border-right: none;
            padding: 10px 16px;
        }
        
        .header-search .form-control:focus {
            box-shadow: none;
            border-color: #c5c6c9;
        }
        
        .header-search .btn {
            background-color: #222325;
            color: white;
            border: 1px solid #222325;
            padding: 0 16px;
        }
        
        .header-search .btn:hover {
            background-color: #404145;
        }

        /* Nav Links */
        .nav-link {
            color: #62646a !important;
            font-weight: 600;
            font-size: 16px;
            padding: 0 12px !important;
        }
        
        .nav-link:hover {
            color: var(--fiverr-green) !important;
        }
        
        .nav-link.active {
            color: var(--fiverr-green) !important;
        }

        .nav-icon {
            font-size: 1.2rem;
            color: #74767e;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            background-color: var(--fiverr-green);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
            cursor: pointer;
        }

        /* Categories Navbar */
        .navbar-categories {
            background-color: #fff;
            border-bottom: 1px solid #e4e5e7;
            padding: 0;
            position: fixed;
            top: 73px; /* Height of main navbar */
            left: 0;
            right: 0;
            z-index: 999;
            overflow-x: auto;
            white-space: nowrap;
        }
        
        .navbar-categories::-webkit-scrollbar {
            height: 0px;
        }

        .cat-link {
            display: inline-block;
            padding: 10px 15px;
            color: #74767e;
            text-decoration: none;
            font-size: 14px;
            border-bottom: 2px solid transparent;
        }
        
        .cat-link:hover {
            color: #404145;
            border-bottom: 2px solid #404145;
        }
        
        .pro-link {
            color: var(--fiverr-green) !important;
        }

        /* User Dropdown Menu Styles */
        .user-menu-header {
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            background-color: #fff;
        }
        
        .user-menu-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            overflow: hidden;
            flex-shrink: 0;
            background-color: var(--fiverr-green);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
        }
        
        .user-menu-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .user-menu-info {
            flex-grow: 1;
            overflow: hidden;
        }
        
        .user-menu-name {
            font-weight: 700;
            color: #404145;
            font-size: 16px;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .user-menu-link {
            color: var(--fiverr-green);
            text-decoration: none;
            font-size: 14px;
            display: block;
        }
        
        .user-menu-link:hover {
            text-decoration: underline;
            color: var(--fiverr-green);
        }
        
        .dropdown-item {
            padding: 10px 16px;
            font-size: 15px;
            color: #74767e;
        }
        
        .dropdown-item:hover {
            background-color: #f5f5f5;
            color: #404145;
        }
        
        .custom-dropdown-menu {
            border: 1px solid #e4e5e7;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            border-radius: 4px;
            padding-top: 0;
            padding-bottom: 8px;
            margin-top: 10px;
            width: 280px;
        }

        /* Mobile Responsive Styles */
        @media (max-width: 991.98px) {
            body {
                padding-top: 120px; /* Adjusted for navbar + categories height */
            }
            
            .navbar-main {
                padding: 10px 0;
            }

            .header-search {
                margin: 15px 0;
                width: 100%;
                max-width: 100%;
            }

            .navbar-categories {
                top: auto; /* Let it flow naturally if needed, or stick below */
                position: fixed;
                top: 65px; /* Adjust based on main navbar height */
            }
            
            /* Dropdown fixes for mobile */
            .navbar-nav .dropdown-menu {
                position: static;
                float: none;
                width: 100%;
                margin-top: 0;
                background-color: #f9f9f9;
                border: none;
                box-shadow: none;
                padding-left: 10px;
                padding-right: 10px;
            }

            .custom-dropdown-menu {
                width: 100%;
                box-shadow: none;
                border: 1px solid #eee;
            }

            .user-menu-header {
                flex-direction: row;
                background-color: transparent;
            }
            
            .nav-link {
                padding: 10px 0 !important;
                border-bottom: 1px solid #eee;
            }
            
            .navbar-collapse {
                background: white;
                padding: 15px;
                border-radius: 0 0 10px 10px;
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                max-height: 80vh;
                overflow-y: auto;
            }
        }
    </style>
</head>
<body>

    <!-- Main Navbar -->
    <nav class="navbar navbar-expand-lg navbar-main">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand me-4" href="/">
                <% if ((typeof lang !== 'undefined' ? lang : 'tr') === 'tr') { %>
                    İŞBUL.ONLINE<span>.</span>
                <% } else { %>
                    UpRemote
                <% } %>
            </a>

            <!-- Toggle Button for Mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <!-- Search Bar -->
                <form class="header-search d-flex me-auto" action="/jobs/search" method="GET">
    <input class="form-control" type="search" name="search" placeholder="<%= t('header.search_placeholder') %>">
    <button class="btn" type="submit">
        <i class="bi bi-search"></i>
    </button>
</form>

                <!-- Right Menu -->
                <ul class="navbar-nav align-items-center ms-auto mb-2 mb-lg-0">
                    
                    <!-- Language Selector -->
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-globe"></i> <%= (typeof lang !== 'undefined' ? lang : 'tr') === 'tr' ? 'TR' : 'EN' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width: 80px;">
                            <li><a class="dropdown-item <%= (typeof lang !== 'undefined' ? lang : 'tr') === 'tr' ? 'active' : '' %>" href="?lang=tr">Türkçe</a></li>
                            <li><a class="dropdown-item <%= (typeof lang !== 'undefined' ? lang : 'tr') === 'en' ? 'active' : '' %>" href="?lang=en">English</a></li>
                        </ul>
                    </li>
                    
                    <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated && typeof user !== 'undefined' && user) { %>
                        
                        <li class="nav-item dropdown ms-2">
                            <a class="nav-link p-0 d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar">
                                    <%= user.name ? user.name.charAt(0).toUpperCase() : (user.email ? user.email.charAt(0).toUpperCase() : 'U') %>
                                </div>
                                <span class="fw-bold text-dark d-none d-lg-block" style="font-size: 14px;">
                                    <%= user.name || user.email %>
                                </span>
                                <i class="bi bi-chevron-down text-muted" style="font-size: 12px;"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end custom-dropdown-menu">
                                <li>
                                    <div class="user-menu-header">
                                        <div class="user-menu-avatar">
                                            <%= user.name ? user.name.charAt(0).toUpperCase() : (user.email ? user.email.charAt(0).toUpperCase() : 'U') %>
                                        </div>
                                        <div class="user-menu-info">
                                            <div class="user-menu-name"><%= user.name || user.email %></div>
                                            <a href="/profile" class="user-menu-link"><%= t('header.go_to_profile') %></a>
                                            <a href="/jobs/dashboard" class="user-menu-link"><%= t('header.dashboard') %></a>
                                        </div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider m-0"></li>
                                <li><a class="dropdown-item mt-2" href="/settings"><%= t('header.settings') %></a></li>
                                <li><a class="dropdown-item" href="/help"><%= t('header.help') %></a></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout"><%= t('common.logout') %></a></li>
                            </ul>
                        </li>
                    <% } else { %>
                         
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/login"><%= t('common.login') %></a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-outline-success fw-bold px-3" style="color: var(--fiverr-green); border-color: var(--fiverr-green);" href="/auth/register"><%= t('common.join') %></a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
