<%- include('../includes/header') %>

<style>
    .dashboard-title i {
        background: linear-gradient(135deg, #6fd819, #20c997);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .table thead th {
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .job-logo {
        width: 48px;
        height: 48px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #e9ecef;
    }

    .logo-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: #f1f3f5;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
    }

    .action-btns .btn {
        width: 34px;
        height: 34px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container py-5" style="min-height: 80vh;">

    <!-- Back -->
    <div class="mb-4">
        <a href="/" class="btn btn-link text-decoration-none text-muted p-0">
            <i class="bi bi-arrow-left-circle me-1"></i> <%= t('jobs.dashboard.back_to_all') %>
        </a>
    </div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1 dashboard-title">
                <i class="bi bi-speedometer2 me-2"></i><%= t('jobs.dashboard.title') %>
            </h2>
            <p class="text-muted mb-0">
                <%= t('jobs.dashboard.total_active_jobs') %> <span class="fw-bold text-primary"><%= jobs.length %></span>
            </p>
        </div>

        <a href="/jobs/create" class="btn btn-success shadow-sm px-4 py-2">
            <i class="bi bi-plus-circle me-1"></i> <%= t('jobs.dashboard.create_new_job') %>
        </a>
    </div>

    <!-- Table -->
    <div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-uppercase fw-bold text-muted">
                        <th class="ps-4 py-3"><%= t('jobs.dashboard.table.position') %></th>
                        <th class="py-3"><%= t('jobs.dashboard.table.location') %></th>
                        <th class="py-3"><%= t('jobs.dashboard.table.job_type') %></th>
                        <th class="py-3"><%= t('jobs.dashboard.table.date') %></th>
                        <th class="text-center pe-4 py-3"><%= t('jobs.dashboard.table.actions') %></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (jobs.length > 0) { %>
                        <% jobs.forEach(job => { %>
                            <tr>
                                <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center">
                                        <% if (job.companyLogo) { %>
                                            <img src="/uploads/<%= job.companyLogo %>" class="job-logo me-3">
                                        <% } else { %>
                                            <div class="logo-placeholder me-3">
                                                <i class="bi bi-building"></i>
                                            </div>
                                        <% } %>

                                        <div>
                                            <div class="fw-bold text-dark"><%= job.title %></div>
                                            <div class="text-muted small"><%= job.companyName %></div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="text-muted small">
                                        <i class="bi bi-geo-alt text-danger me-1"></i>
                                        <%= job.location %>
                                    </span>
                                </td>

                                <td>
                                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 fw-normal">
                                        <%= job.jobType %>
                                    </span>
                                </td>

                                <td>
                                    <span class="text-muted small">
                                        <%= new Date(job.createdAt).toLocaleDateString((typeof lang !== 'undefined' ? lang : 'tr') === 'tr' ? 'tr-TR' : 'en-US', {
                                            day: 'numeric',
                                            month: 'short',
                                            year: 'numeric'
                                        }) %>
                                    </span>
                                </td>

                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2 action-btns">
                                        <a href="/jobs/<%= job.id %>" class="btn btn-outline-primary btn-sm" title="<%= t('jobs.common.view') %>">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a href="/jobs/edit/<%= job.id %>" class="btn btn-outline-warning btn-sm" title="<%= t('jobs.common.edit') %>">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <form action="/jobs/delete/<%= job.id %>" method="POST"
                                              onsubmit="return confirm('<%= t('jobs.common.delete_confirm') %>')">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="<%= t('jobs.common.delete') %>">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted"></i>
                                <p class="text-muted mt-2 mb-0">
                                    <%= t('jobs.dashboard.empty_state') %>
                                </p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</div>

<%- include('../includes/footer') %>
