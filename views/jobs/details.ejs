<%- include('../includes/header') %>

<div class="container py-5">
    <div class="mb-4">
        <a href="/" class="btn btn-link text-decoration-none text-muted p-0">
            <i class="bi bi-arrow-left-circle me-1"></i> <%= t('jobs.details.back_to_listings') %>
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 16px;">
                <div class="d-flex align-items-center mb-4">
                    <% if (job.companyLogo) { %>
                        <img src="/uploads/<%= job.companyLogo %>" class="rounded-3 shadow-sm border me-3" style="width: 80px; height: 80px; object-fit: cover;">
                    <% } else { %>
                        <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-building text-primary fs-1"></i>
                        </div>
                    <% } %>
                    <div>
                        <h2 class="fw-bold text-dark mb-1"><%= job.title %></h2>
                        <h5 class="text-primary mb-0"><%= job.companyName %></h5>
                    </div>
                </div>

                <hr class="text-light">

                <div class="my-4">
                    <h5 class="fw-bold mb-3"><%= t('jobs.details.job_description') %></h5>
                    <p class="text-secondary style-description" style="line-height: 1.8; white-space: pre-line;">
                        <%= job.description %>
                    </p>
                </div>

                <div class="d-grid mt-4">
                    <button type="button" class="btn btn-success btn-lg py-3 fw-bold shadow-sm" style="border-radius: 12px;" data-bs-toggle="modal" data-bs-target="#applicationModal">
                        <%= t('jobs.details.apply_button') %>
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 sticky-top" style="border-radius: 16px; top: 20px;">
                <h5 class="fw-bold mb-4"><%= t('jobs.details.summary') %></h5>
                
                <div class="d-flex align-items-start mb-3">
                    <div class="bg-light p-2 rounded-3 me-3">
                        <i class="bi bi-geo-alt text-danger fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block"><%= t('jobs.details.location') %></small>
                        <span class="fw-bold text-dark"><%= job.location %></span>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                    <div class="bg-light p-2 rounded-3 me-3">
                        <i class="bi bi-briefcase text-primary fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block"><%= t('jobs.details.job_type') %></small>
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 fw-normal"><%= job.jobType %></span>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                    <div class="bg-light p-2 rounded-3 me-3">
                        <i class="bi bi-cash-stack text-success fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block"><%= t('jobs.details.salary_range') %></small>
                        <span class="fw-bold text-dark">$<%= job.salary.toLocaleString() %></span>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <div class="bg-light p-2 rounded-3 me-3">
                        <i class="bi bi-calendar-event text-info fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block"><%= t('jobs.details.date_posted') %></small>
                        <span class="text-dark small"><%= new Date(job.createdAt).toLocaleDateString((typeof lang !== 'undefined' ? lang : 'tr') === 'tr' ? 'tr-TR' : 'en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                </div>

                <% if (isAuthenticated && user && String(job.userId) === String(user.id)) { %>
                    <div class="border-top pt-4">
                        <p class="small text-muted mb-2 text-center"><%= t('jobs.details.manage_listing') %></p>
                        <div class="d-flex gap-2">
                            <a href="/jobs/edit/<%= job.id %>" class="btn btn-outline-warning w-100 btn-sm py-2">
                                <i class="bi bi-pencil-square me-1"></i> <%= t('jobs.details.edit') %>
                            </a>
                            <form action="/jobs/delete/<%= job.id %>" method="POST" class="w-100" onsubmit="return confirm('<%= t('jobs.details.delete_confirm') %>')">
                                <button type="submit" class="btn btn-outline-danger w-100 btn-sm py-2">
                                    <i class="bi bi-trash3 me-1"></i> <%= t('jobs.details.delete') %>
                                </button>
                            </form>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Application Modal -->
<div class="modal fade" id="applicationModal" tabindex="-1" aria-labelledby="applicationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="applicationModalLabel"><%= t('jobs.application.title') %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <form action="/jobs/<%= job.id %>/apply" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-bold"><%= t('jobs.application.full_name') %></label>
                <input type="text" name="fullName" class="form-control" value="<%= user ? (user.Profile ? user.Profile.firstName + ' ' + user.Profile.lastName : '') : '' %>" required>
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold"><%= t('jobs.application.email') %></label>
                <input type="email" name="email" class="form-control" value="<%= user ? user.email : '' %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold"><%= t('jobs.application.phone') %></label>
                <input type="tel" name="phone" class="form-control" placeholder="+90 555 123 4567" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold"><%= t('jobs.application.cv') %></label>
                <input type="file" name="cv" class="form-control" accept=".pdf,.doc,.docx" required>
                <div class="form-text"><%= t('jobs.application.cv_hint') %></div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold"><%= t('jobs.application.cover_letter') %></label>
                <textarea name="coverLetter" class="form-control" rows="4" placeholder="<%= t('jobs.application.cover_letter_placeholder') %>"></textarea>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-success fw-bold py-2"><%= t('jobs.application.submit') %></button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../includes/footer') %>
