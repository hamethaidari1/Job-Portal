<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-lg">
                <div class="card-header bg-white p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 text-primary"><%= job.title %></h2>
                        <span class="badge bg-success fs-6"><%= job.jobType %></span>
                    </div>
                    <h5 class="text-muted mt-2"><%= job.companyName %></h5>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt-fill"></i> <%= job.location %> | 
                        <i class="bi bi-cash-stack"></i> <%= job.salary || 'Negotiable' %>
                    </p>
                </div>
                
                <div class="card-body p-4">
                    <h5 class="fw-bold">Job Description</h5>
                    <p class="card-text" style="white-space: pre-line;"><%= job.description %></p>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="mailto:HR@example.com?subject=Application for <%= job.title %>" class="btn btn-primary btn-lg"><%= t('jobs.show.apply_now') %></a>
                        <a href="/jobs" class="btn btn-outline-secondary btn-lg"><%= t('jobs.show.back_to_jobs') %></a>

                        <% if (user) { %>
                            <div class="ms-auto d-flex gap-2">
                                <a href="/jobs/<%= job.id %>/edit" class="btn btn-warning btn-lg"><%= t('jobs.show.edit') %></a>
                                
                                <form action="/jobs/<%= job.id %>/delete" method="POST" onsubmit="return confirm('<%= t('jobs.show.delete_confirm') %>');">
                                    <button type="submit" class="btn btn-danger btn-lg"><%= t('jobs.show.delete') %></button>
                                </form>
                            </div>
                        <% } %>
                    </div>
