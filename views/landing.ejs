<%- include('includes/header') %>

<style>
    .landing-hero {
        background-color: #183823; 
        color: white; 
        padding: 25px 0 15px; 
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        min-height: 400px;
    }
    
    .landing-hero::before {
        content: "";
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background: url('https://placehold.co/1920x600/023a15/055220?text=İŞBUL+ONLINE') center/cover;
        opacity: 0.1;
    }

    .landing-content { position: relative; z-index: 1; }
    .landing-hero h1 { font-size: 2.8rem; margin-bottom: 20px; }

    /* --- How It Works Styles --- */
    .toggle-pill-wrapper {
        background: #f1f1f1;
        border-radius: 50px;
        padding: 5px;
        display: inline-flex;
        border: 1px solid #e4e5e7;
    }
    
    .toggle-btn {
        border: none;
        background: transparent;
        padding: 8px 25px;
        font-weight: 700;
        color: #62646a;
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 25px;
        font-size: 0.9rem;
    }
    
    .toggle-btn.active {
        background-color: #000;
        color: #fff;
    }

    .video-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid #efeff0;
        height: 100%;
    }

    .video-card:hover {
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    .video-card video {
        width: 100%;
        background: #000;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
    }

    .card-text-content { padding: 20px; }
    .card-text-content h6 { font-weight: 700; color: #404145; margin-bottom: 10px; }
    .card-text-content p { font-size: 14px; color: #62646a; margin: 0; line-height: 1.5; }

    /* Feature Icons */
    .feature-icon-box {
        width: 70px; height: 70px;
        background-color: #f4fdf7;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 15px;
        color: #1dbf73; font-size: 1.8rem;
        transition: transform 0.3s;
    }

    .feature-card:hover .feature-icon-box {
        transform: scale(1.1); background-color: #1dbf73; color: white;
    }

    /* Mobile Responsive Styles */
    @media (max-width: 768px) {
        .landing-hero {
            min-height: auto;
            padding: 60px 0 40px;
            text-align: center;
        }

        .landing-hero h1 {
            font-size: 2rem;
            margin-bottom: 15px;
        }

        .landing-hero .lead {
            font-size: 1rem;
            margin-bottom: 30px !important;
        }

        .search-bar-container form {
            flex-direction: column;
            width: 100%;
        }

        .search-bar-container input {
            max-width: 100% !important;
            margin-bottom: 10px;
        }

        .search-bar-container button {
            width: 100%;
        }

        .d-flex.justify-content-center.gap-3 {
            flex-direction: column;
            gap: 15px !important;
        }

        .d-flex.justify-content-center.gap-3 a {
            width: 100%;
        }

        .toggle-pill-wrapper {
            margin-top: 15px;
            width: 100%;
            justify-content: center;
        }

        .toggle-btn {
            padding: 8px 15px;
            font-size: 0.85rem;
            flex: 1;
            text-align: center;
        }

        .video-card {
            margin-bottom: 20px;
        }
        
        /* Why Choose Section on Mobile */
        .feature-card {
            margin-bottom: 30px;
        }
    }
</style>

<div class="landing-hero">
    <div class="container landing-content text-center">
        <h1 class="display-3 fw-bold mb-4"><%- t('landing.hero_title') %></h1>
        <p class="lead mb-5 opacity-75" style="max-width: 700px; margin: 0 auto;">
            <%= t('landing.hero_subtitle') %>
        </p>
        
        <div class="search-bar-container mb-5">
            <form action="/jobs/search" method="GET" class="d-flex justify-content-center gap-2">
                <input type="text" name="q" class="form-control form-control-lg" style="max-width: 400px;" placeholder="Bugün hangi hizmeti arıyorsunuz?">
                <button type="submit" class="btn btn-success btn-lg"><%= t('common.search') %></button>
            </form>
        </div>
        
        <div class="d-flex justify-content-center gap-3 mb-5">
            <a href="/auth/register" class="btn btn-success btn-lg px-5 py-3 fw-bold shadow-sm"><%= t('landing.join_button') %></a>
            <a href="/auth/login" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold"><%= t('common.login') %></a>
        </div>
    </div>
</div>

<div class="container py-5 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-3 mb-md-0" style="color: #404145;">Nasıl Çalışır?</h2>
        
        <div class="toggle-pill-wrapper">
            <button class="toggle-btn active" id="hiring-tab" onclick="switchTab('hiring')">İşveren İçin</button>
            <button class="toggle-btn" id="finding-tab" onclick="switchTab('finding')">Çalışan İçin</button>
        </div>
    </div>

    <div id="hiring-content" class="row g-4">
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/İŞBUL . ONLINE.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>İş İlanı Verin</h6>
                    <p>İhtiyacınızı detaylandırın ve ücretsiz ilanınızı yayınlayın.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/Review proposals.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>Teklifleri İnceleyin</h6>
                    <p>Freelancer profillerini ve tekliflerini karşılaştırın.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/Hire and get work done.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>İşi Tamamlayın</h6>
                    <p>Güvenli ödeme ile işinizi yaptırın ve onay verin.</p>
                </div>
            </div>
        </div>
    </div>

    <div id="finding-content" class="row g-4" style="display: none;">
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/Create your profile.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>Profil Oluşturun</h6>
                    <p>Yeteneklerinizi sergileyin ve portfolyonuzu ekleyin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/Search for jobs.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>İş Arayın</h6>
                    <p>Uzmanlığınıza uygun projeleri bulun ve teklif verin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="video-card">
                <video autoplay muted loop playsinline>
                    <source src="/video/Get paid securely.mp4" type="video/mp4">
                </video>
                <div class="card-text-content">
                    <h6>Ödemenizi Alın</h6>
                    <p>İşi teslim edin ve ödemenizi güvenle alın.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 my-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold"><%= t('landing.why_choose_title') %></h2>
        <p class="text-muted"><%= t('landing.why_choose_subtitle') %></p>
    </div>

    <div class="row g-4">
        <div class="col-md-3 text-center feature-card">
            <div class="feature-icon-box"><i class="bi bi-search"></i></div>
            <h5 class="fw-bold"><%= t('landing.feature_browse_title') %></h5>
            <p class="text-muted small"><%= t('landing.feature_browse_desc') %></p>
        </div>
        <div class="col-md-3 text-center feature-card">
            <div class="feature-icon-box"><i class="bi bi-file-earmark-text"></i></div>
            <h5 class="fw-bold"><%= t('landing.feature_bids_title') %></h5>
            <p class="text-muted small"><%= t('landing.feature_bids_desc') %></p>
        </div>
        <div class="col-md-3 text-center feature-card">
            <div class="feature-icon-box"><i class="bi bi-award"></i></div>
            <h5 class="fw-bold"><%= t('landing.feature_quality_title') %></h5>
            <p class="text-muted small"><%= t('landing.feature_quality_desc') %></p>
        </div>
        <div class="col-md-3 text-center feature-card">
            <div class="feature-icon-box"><i class="bi bi-shield-check"></i></div>
            <h5 class="fw-bold"><%= t('landing.feature_safe_title') %></h5>
            <p class="text-muted small"><%= t('landing.feature_safe_desc') %></p>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        const hiringContent = document.getElementById('hiring-content');
        const findingContent = document.getElementById('finding-content');
        const hiringBtn = document.getElementById('hiring-tab');
        const findingBtn = document.getElementById('finding-tab');
        
        if (tab === 'hiring') {
            hiringContent.style.display = 'flex';
            findingContent.style.display = 'none';
            hiringBtn.classList.add('active');
            findingBtn.classList.remove('active');
        } else {
            hiringContent.style.display = 'none';
            findingContent.style.display = 'flex';
            hiringBtn.classList.remove('active');
            findingBtn.classList.add('active');
        }
    }
</script>

<%- include('includes/footer') %>