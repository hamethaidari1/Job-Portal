<%- include('includes/header') %>

<style>
    .profile-card {
        background: rgba(255,255,255,0.92);
        border-radius: 18px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border: 1px solid rgba(255,255,255,0.5);
    }

    .avatar-circle {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #42c157, #488d45);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        font-weight: bold;
        margin: 0 auto;
        box-shadow: 0 10px 25px rgba(66, 193, 87, 0.4);
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 14px;
        height: 100%;
    }

    .info-label {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 600;
        color: #212529;
    }

    .btn-purple {
        background: linear-gradient(135deg, #49eb72, #3eaa6f);
        border: none;
        color: #fff;
        border-radius: 10px;
        padding: 10px 22px;
    }

    .btn-purple:hover {
        opacity: 0.9;
        color: #fff;
    }
</style>

<div class="container py-5">
    <div class="row g-4">

        <!-- USER CARD -->
        <div class="col-lg-4">
            <div class="profile-card p-4 text-center h-100">
                <div class="avatar-circle mb-3">
                    <%= (user.name || user.email || 'U').charAt(0).toUpperCase() %>
                </div>

                <h5 class="fw-bold mb-1">
                    <%= user.name || 'Kullanıcı' %>
                </h5>

                <p class="text-muted small mb-4">
                    <%= user.email %>
                </p>

                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a href="/settings" class="btn btn-outline-secondary btn-sm">
                        Ayarlar
                    </a>
                    <a href="/jobs/dashboard" class="btn btn-success btn-sm">
                        Kontrol Paneli
                    </a>
                </div>
            </div>
        </div>

        <!-- PERSONAL INFO -->
        <div class="col-lg-8">
            <div class="profile-card p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-person-lines-fill fs-4 text-primary me-2"></i>
                    <h5 class="fw-bold mb-0">
                        Kişisel Bilgiler
                    </h5>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-label">Ad</div>
                            <div class="info-value">
                                <%= (profile && profile.firstName) || '-' %>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-label">Soyad</div>
                            <div class="info-value">
                                <%= (profile && profile.lastName) || '-' %>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-label">Konum</div>
                            <div class="info-value">
                                <%= (profile && profile.location) || '-' %>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-label">Doğum Tarihi</div>
                            <div class="info-value">
                                <%= (profile && profile.birthDate) || '-' %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <a href="/settings" class="btn btn-purple fw-bold">
                        Bilgileri Düzenle
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('includes/footer') %>
